# ==============================================================================
# POTLIFT8 ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env for local development
# Never commit .env to version control

# ==============================================================================
# AUTHLIFT8 OAUTH2 CONFIGURATION
# ==============================================================================
# OAuth2 client credentials for Authlift8 authentication service
# Required for user authentication and authorization

# OAuth2 Client ID (obtained from Authlift8 admin panel)
AUTHLIFT8_CLIENT_ID=your_client_id_here

# OAuth2 Client Secret (obtained from Authlift8 admin panel)
# SECURITY: Keep this secret! Never expose in client-side code
AUTHLIFT8_CLIENT_SECRET=your_client_secret_here

# Authlift8 Base URL
# Production: https://auth.yourdomain.com
# Development: http://localhost:3231
AUTHLIFT8_SITE=http://localhost:3231

# OAuth2 Redirect URI (callback URL)
# Must match the redirect URI registered in Authlift8
# Production: https://potlift8.yourdomain.com/auth/callback
# Development: http://localhost:3246/auth/callback
AUTHLIFT8_REDIRECT_URI=http://localhost:3246/auth/callback

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
DATABASE_URL=postgresql://potlift:password@localhost/potlift8_development
POSTGRES_USER=potlift
POSTGRES_PASSWORD=password

# ==============================================================================
# REDIS CONFIGURATION
# ==============================================================================
REDIS_URL=redis://localhost:6379/0

# ==============================================================================
# RAILS CONFIGURATION
# ==============================================================================
RAILS_ENV=development
PORT=3246
RAILS_MAX_THREADS=5

# Rails secret key base (generate with: rails secret)
# SECURITY: Must be unique per environment and kept secret
# SECRET_KEY_BASE=

# ==============================================================================
# SETUP INSTRUCTIONS
# ==============================================================================
#
# 1. Copy this file:
#    $ cp .env.example .env
#
# 2. Update OAuth2 credentials:
#    - Login to Authlift8 admin panel at http://localhost:3231
#    - Create new OAuth2 client for Potlift8
#    - Copy Client ID and Client Secret to .env
#    - Register redirect URI: http://localhost:3246/auth/callback
#
# 3. Update database configuration if needed
#
# 4. Install dependencies:
#    $ bundle install
#
# 5. Setup database:
#    $ rails db:create db:migrate
#
# 6. Start Rails server:
#    $ rails server -p 3246
#
# 7. Test OAuth flow:
#    - Visit http://localhost:3246/auth/login
#    - Complete authentication on Authlift8
#    - Should redirect back to app with session
#
# ==============================================================================
# SECURITY NOTES
# ==============================================================================
#
# - Never commit .env to version control (already in .gitignore)
# - Use different credentials for each environment
# - Rotate secrets regularly in production
# - Keep AUTHLIFT8_CLIENT_SECRET secure
# - Use HTTPS in production (update AUTHLIFT8_SITE and AUTHLIFT8_REDIRECT_URI)
# - Enable force_ssl in production environment
#
