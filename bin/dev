#!/usr/bin/env bash
# bin/dev - Start development server with service checks

set -e

# Check if PostgreSQL is running
if ! pg_isready -q 2>/dev/null; then
  echo "ERROR: PostgreSQL is not running."
  echo "Start it with: brew services start postgresql@16"
  echo "Or on Linux: sudo systemctl start postgresql"
  exit 1
fi

# Check if Redis is running
if ! redis-cli ping > /dev/null 2>&1; then
  echo "ERROR: Redis is not running."
  echo "Start it with: brew services start redis"
  echo "Or on Linux: sudo systemctl start redis-server"
  exit 1
fi

# Check if .env file exists
if [ ! -f .env ]; then
  echo "ERROR: .env file not found."
  echo "Run 'bin/setup' first to create it from .env.example"
  exit 1
fi

# Install foreman if not present
if ! gem list foreman -i --silent; then
  echo "Installing foreman..."
  gem install foreman
fi

# Set port to 3246 (override default)
export PORT=3246

# Let the debug gem allow remote connections,
# but avoid loading until 'debugger' is called
export RUBY_DEBUG_OPEN="true"
export RUBY_DEBUG_LAZY="true"

echo "Starting Potlift8 on http://localhost:3246..."
echo "Press Ctrl+C to stop"
echo ""

exec foreman start -f Procfile.dev "$@"
