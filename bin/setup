#!/usr/bin/env bash
# bin/setup - Initial setup script for Potlift8

set -e

echo "==> Installing dependencies..."
bundle check || bundle install

# Install yarn dependencies if package.json exists
if [ -f "package.json" ]; then
  echo "==> Installing JavaScript dependencies..."
  yarn install
fi

echo "==> Loading environment variables..."
if [ ! -f .env ]; then
  cp .env.example .env
  echo "Created .env file. Please update with your credentials."
  echo "IMPORTANT: Update AUTHLIFT8_CLIENT_ID and AUTHLIFT8_CLIENT_SECRET in .env"
fi

echo "==> Creating PostgreSQL user and database..."
# Create user if it doesn't exist (ignore error if it does)
createuser -s potlift 2>/dev/null || echo "User 'potlift' already exists, skipping creation."

# Create databases if they don't exist
createdb potlift8_development 2>/dev/null || echo "Database 'potlift8_development' already exists, skipping creation."
createdb potlift8_test 2>/dev/null || echo "Database 'potlift8_test' already exists, skipping creation."

echo "==> Setting up database..."
bin/rails db:prepare

echo "==> Removing old logs and tempfiles..."
bin/rails log:clear tmp:clear

echo ""
echo "==> Setup complete!"
echo ""
echo "Next steps:"
echo "  1. Update .env with your Authlift8 credentials"
echo "  2. Run 'bin/dev' to start the development server"
echo "  3. Visit http://localhost:3246"
echo ""
