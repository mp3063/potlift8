<li class="px-4 py-4 sm:px-6 hover:bg-gray-50 cursor-move" data-attribute-id="<%= attribute.id %>">
  <div class="flex items-center justify-between">
    <div class="flex items-center min-w-0 flex-1">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5" />
        </svg>
      </div>
      <div class="ml-4 flex-1">
        <div class="flex items-center">
          <p class="truncate text-sm font-medium text-blue-600">
            <%= link_to attribute.name, edit_product_attribute_path(attribute) %>
          </p>
          <% if attribute.mandatory? %>
            <span class="ml-2 inline-flex items-center rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700 ring-1 ring-inset ring-red-600/20">
              Required
            </span>
          <% end %>
        </div>
        <div class="mt-1 flex items-center gap-x-4">
          <p class="text-sm text-gray-500">
            Code: <code class="text-xs bg-gray-100 px-1 py-0.5 rounded"><%= attribute.code %></code>
          </p>
          <p class="text-sm text-gray-500">
            Format: <span class="font-medium"><%= attribute.view_format.to_s.sub('view_format_', '').titleize %></span>
          </p>
          <p class="text-sm text-gray-500">
            Type: <span class="font-medium"><%= attribute.pa_type.to_s.sub('patype_', '').titleize %></span>
          </p>
        </div>
      </div>
    </div>
    <div class="ml-4 flex-shrink-0 flex gap-x-2">
      <%= link_to edit_product_attribute_path(attribute), class: "text-gray-400 hover:text-gray-500" do %>
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
        </svg>
        <span class="sr-only">Edit</span>
      <% end %>

      <%= button_to product_attribute_path(attribute), method: :delete, form: { data: { turbo_confirm: "Delete this attribute? This cannot be undone." } }, class: "text-red-400 hover:text-red-500" do %>
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
        </svg>
        <span class="sr-only">Delete</span>
      <% end %>
    </div>
  </div>
</li>
