<div class="md:flex md:items-center md:justify-between mb-8">
  <div class="min-w-0 flex-1">
    <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-3xl sm:tracking-tight">
      <%= @product_attribute.name %>
    </h2>
    <p class="mt-1 text-sm text-gray-500">
      Code: <code class="bg-gray-100 px-2 py-1 rounded text-xs"><%= @product_attribute.code %></code>
    </p>
  </div>
  <div class="mt-4 flex md:ml-4 md:mt-0 gap-x-3">
    <%= link_to product_attributes_path, class: "inline-flex items-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" do %>
      <svg class="-ml-0.5 mr-1.5 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      Back to Attributes
    <% end %>

    <%= render Ui::ButtonComponent.new(
      variant: :primary,
      href: edit_product_attribute_path(@product_attribute.code),
      icon: '<svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" /></svg>',
      icon_position: :left
    ) do %>
      Edit
    <% end %>
  </div>
</div>

<div class="space-y-6">
  <!-- Attribute Details Card -->
  <div class="bg-white shadow-sm ring-1 ring-gray-900/5 sm:rounded-lg">
    <div class="px-4 py-6 sm:px-6">
      <h3 class="text-base font-semibold leading-7 text-gray-900">Attribute Details</h3>
      <p class="mt-1 max-w-2xl text-sm leading-6 text-gray-500">Basic information and configuration</p>
    </div>
    <div class="border-t border-gray-100">
      <dl class="divide-y divide-gray-100">
        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-900">Name</dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">
            <%= @product_attribute.name %>
          </dd>
        </div>

        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-900">Code</dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">
            <code class="bg-gray-100 px-2 py-1 rounded text-xs"><%= @product_attribute.code %></code>
          </dd>
        </div>

        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-900">Type</dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">
            <span class="inline-flex items-center rounded-full bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10">
              <%= @product_attribute.pa_type.to_s.gsub('patype_', '').titleize %>
            </span>
          </dd>
        </div>

        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-900">View Format</dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">
            <%= @product_attribute.view_format.to_s.gsub('view_format_', '').titleize %>
          </dd>
        </div>

        <% if @product_attribute.attribute_group.present? %>
          <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-900">Group</dt>
            <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">
              <%= @product_attribute.attribute_group.name %>
            </dd>
          </div>
        <% end %>

        <% if @product_attribute.description.present? %>
          <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-900">Description</dt>
            <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">
              <%= @product_attribute.description %>
            </dd>
          </div>
        <% end %>

        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-900">Flags</dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">
            <div class="flex flex-wrap gap-2">
              <% if @product_attribute.mandatory? %>
                <span class="inline-flex items-center rounded-full bg-red-50 px-2 py-1 text-xs font-medium text-red-700 ring-1 ring-inset ring-red-600/10">
                  Mandatory
                </span>
              <% end %>
            </div>
          </dd>
        </div>

        <% if @product_attribute.info['options'].present? %>
          <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-900">Options</dt>
            <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">
              <ul class="list-disc list-inside space-y-1">
                <% @product_attribute.info['options'].each do |option| %>
                  <li><%= option %></li>
                <% end %>
              </ul>
            </dd>
          </div>
        <% end %>
      </dl>
    </div>
  </div>

  <!-- Products Using This Attribute -->
  <% if @attribute_values.any? %>
    <div class="bg-white shadow-sm ring-1 ring-gray-900/5 sm:rounded-lg">
      <div class="px-4 py-6 sm:px-6">
        <h3 class="text-base font-semibold leading-7 text-gray-900">Products Using This Attribute</h3>
        <p class="mt-1 max-w-2xl text-sm leading-6 text-gray-500">Showing up to 50 products</p>
      </div>
      <div class="border-t border-gray-100">
        <ul role="list" class="divide-y divide-gray-100">
          <% @attribute_values.each do |av| %>
            <li class="flex items-center justify-between gap-x-6 px-4 py-5 sm:px-6">
              <div class="min-w-0">
                <div class="flex items-start gap-x-3">
                  <p class="text-sm font-semibold leading-6 text-gray-900">
                    <%= link_to av.product.name, product_path(av.product.sku), class: "text-blue-600 hover:text-blue-700" %>
                  </p>
                </div>
                <div class="mt-1 flex items-center gap-x-2 text-xs leading-5 text-gray-500">
                  <p class="truncate">SKU: <%= av.product.sku %></p>
                </div>
              </div>
              <div class="flex flex-none items-center gap-x-4">
                <div class="text-sm text-gray-900">
                  <% if av.value.present? %>
                    <code class="bg-gray-100 px-2 py-1 rounded text-xs"><%= av.value %></code>
                  <% else %>
                    <span class="text-gray-400 italic">No value</span>
                  <% end %>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>
</div>
