<% content_for :page_header do %>
  <div class="flex items-center justify-between">
    <div>
      <nav class="flex mb-4" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
          <li class="inline-flex items-center">
            <%= link_to "Products", products_path, class: "text-sm text-gray-700 hover:text-blue-600" %>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
              </svg>
              <%= link_to @product.name, product_path(@product), class: "text-sm text-gray-700 hover:text-blue-600" %>
            </div>
          </li>
          <li aria-current="page">
            <div class="flex items-center">
              <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
              </svg>
              <span class="text-sm text-gray-500">Inventory</span>
            </div>
          </li>
        </ol>
      </nav>

      <h1 class="text-2xl font-bold text-gray-900">Inventory Management</h1>
      <p class="mt-2 text-sm text-gray-700">
        <%= @product.sku %> - <%= @product.name %>
      </p>
    </div>

    <div class="flex gap-3">
      <%= link_to "Back to Product", product_path(@product), class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-lg shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
    </div>
  </div>
<% end %>

<div class="space-y-6">
  <!-- Summary Card -->
  <%= render Ui::CardComponent.new do |card| %>
    <% card.with_header do %>
      <h3 class="text-base font-semibold leading-6 text-gray-900">Inventory Summary</h3>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div>
        <dt class="text-sm font-medium text-gray-500">Total Inventory</dt>
        <dd class="mt-1 text-3xl font-bold text-gray-900"><%= @product.total_saldo %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-gray-500">Locations</dt>
        <dd class="mt-1 text-3xl font-bold text-gray-900"><%= @inventories.count %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-gray-500">Status</dt>
        <dd class="mt-1">
          <%= render Ui::BadgeComponent.new(
            variant: @product.product_status == 'active' ? :success : :warning,
            dot: true
          ) do %>
            <%= @product.product_status.titleize %>
          <% end %>
        </dd>
      </div>
    </div>
  <% end %>

  <!-- Inventory by Location -->
  <%= render Ui::CardComponent.new do |card| %>
    <% card.with_header do %>
      <h3 class="text-base font-semibold leading-6 text-gray-900">Inventory by Location</h3>
    <% end %>

    <% if @inventories.any? %>
      <div class="overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
          <thead>
            <tr>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Storage Location</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Type</th>
              <th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-gray-900">Current Stock</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Status</th>
              <th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-gray-900">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 bg-white">
            <% @inventories.each do |inventory| %>
              <tr class="hover:bg-gray-50">
                <td class="whitespace-nowrap px-3 py-4 text-sm">
                  <div class="font-medium text-gray-900"><%= inventory.storage.name %></div>
                  <div class="text-gray-500"><%= inventory.storage.code %></div>
                </td>

                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                  <%= render Ui::BadgeComponent.new(variant: :gray, size: :sm) do %>
                    <%= inventory.storage.storage_type.titleize %>
                  <% end %>
                </td>

                <td class="whitespace-nowrap px-3 py-4 text-sm text-right">
                  <span class="font-semibold text-gray-900"><%= inventory.value || 0 %></span>
                </td>

                <td class="whitespace-nowrap px-3 py-4 text-sm">
                  <% if inventory.value.to_i > 0 %>
                    <%= render Ui::BadgeComponent.new(variant: :success, size: :sm) do %>
                      In Stock
                    <% end %>
                  <% elsif inventory.value.to_i == 0 %>
                    <%= render Ui::BadgeComponent.new(variant: :warning, size: :sm) do %>
                      Out of Stock
                    <% end %>
                  <% else %>
                    <%= render Ui::BadgeComponent.new(variant: :danger, size: :sm) do %>
                      Negative
                    <% end %>
                  <% end %>
                </td>

                <td class="whitespace-nowrap px-3 py-4 text-sm text-right">
                  <%= link_to "Edit", "#",
                    class: "text-blue-600 hover:text-blue-900 font-medium",
                    data: {
                      action: "click->modal#open"
                    } %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
        </svg>
        <h3 class="mt-2 text-sm font-semibold text-gray-900">No inventory records</h3>
        <p class="mt-1 text-sm text-gray-500">This product doesn't have any inventory records yet.</p>
      </div>
    <% end %>
  <% end %>
</div>
