<% content_for :page_header do %>
  <div class="flex items-center justify-between">
    <div>
      <nav class="flex mb-4" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
          <li class="inline-flex items-center">
            <%= link_to "Products", products_path, class: "text-sm text-gray-700 hover:text-blue-600" %>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
              </svg>
              <%= link_to @product.name, product_path(@product), class: "text-sm text-gray-700 hover:text-blue-600" %>
            </div>
          </li>
          <li aria-current="page">
            <div class="flex items-center">
              <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
              </svg>
              <span class="text-sm text-gray-500">Inventory</span>
            </div>
          </li>
        </ol>
      </nav>

      <h1 class="text-2xl font-bold text-gray-900">Inventory Management</h1>
      <p class="mt-2 text-sm text-gray-700">
        <%= @product.sku %> - <%= @product.name %>
        <% if @product.product_type_configurable? %>
          <span class="ml-2">
            <%= render Ui::BadgeComponent.new(variant: :blue, size: :sm) do %>
              Configurable &middot; <%= @subproducts&.size || 0 %> variants
            <% end %>
          </span>
        <% elsif @product.product_type_bundle? %>
          <span class="ml-2">
            <%= render Ui::BadgeComponent.new(variant: :purple, size: :sm) do %>
              Bundle
            <% end %>
          </span>
        <% end %>
      </p>
    </div>

    <div class="flex gap-3">
      <%= link_to "Back to Product", product_path(@product),
          class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-lg shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
    </div>
  </div>
<% end %>

<div class="space-y-6">
  <%# Summary Card %>
  <%= render Ui::CardComponent.new do |card| %>
    <% card.with_header do %>
      <h3 class="text-base font-semibold leading-6 text-gray-900">Inventory Summary</h3>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div>
        <dt class="text-sm font-medium text-gray-500">Total Inventory</dt>
        <dd class="mt-1 text-3xl font-bold text-gray-900">
          <% if @product.product_type_configurable? %>
            <%= @subproducts&.sum { |sp| sp.total_saldo } || 0 %>
          <% else %>
            <%= @product.total_saldo %>
          <% end %>
        </dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Locations</dt>
        <dd class="mt-1 text-3xl font-bold text-gray-900"><%= @storages.count %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Status</dt>
        <dd class="mt-1">
          <%= render Ui::BadgeComponent.new(
            variant: @product.product_status == 'active' ? :success : :warning,
            dot: true
          ) do %>
            <%= @product.product_status.titleize %>
          <% end %>
        </dd>
      </div>
    </div>
  <% end %>

  <% if !@has_inventory && !@product.product_type_bundle? %>
    <%# Setup Wizard %>
    <div data-controller="inventory-setup">
      <%# Step 1: Select Storages %>
      <div data-inventory-setup-target="step1">
        <%= render Ui::CardComponent.new do |card| %>
          <% card.with_header do %>
            <div class="flex items-center justify-between">
              <h3 class="text-base font-semibold leading-6 text-gray-900">Set Up Inventory</h3>
              <span class="text-sm text-gray-500">Step 1 of 2</span>
            </div>
          <% end %>

          <p class="text-sm text-gray-600 mb-4">Select the storage locations where this product will be stocked.</p>

          <div class="flex items-center gap-3 mb-4">
            <button type="button"
                    class="text-sm text-blue-600 hover:text-blue-800 font-medium"
                    data-action="click->inventory-setup#selectAll">
              Select All
            </button>
            <span class="text-gray-300">|</span>
            <button type="button"
                    class="text-sm text-blue-600 hover:text-blue-800 font-medium"
                    data-action="click->inventory-setup#deselectAll">
              Deselect All
            </button>
          </div>

          <div class="space-y-2">
            <% @storages.each do |storage| %>
              <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer">
                <input type="checkbox"
                       value="<%= storage.id %>"
                       data-storage-id="<%= storage.id %>"
                       data-inventory-setup-target="storageCheckbox"
                       data-action="change->inventory-setup#toggleStorage"
                       class="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                       <%= 'checked' if storage.default? %>>
                <div class="flex-1">
                  <span class="font-medium text-gray-900"><%= storage.name %></span>
                  <span class="text-sm text-gray-500 ml-2"><%= storage.code %></span>
                </div>
                <%= render Ui::BadgeComponent.new(variant: :gray, size: :sm) do %>
                  <%= storage.storage_type.titleize %>
                <% end %>
                <% if storage.default? %>
                  <%= render Ui::BadgeComponent.new(variant: :blue, size: :sm) do %>
                    Default
                  <% end %>
                <% end %>
              </label>
            <% end %>
          </div>

          <div class="mt-6">
            <button type="button"
                    class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
                    data-inventory-setup-target="continueButton"
                    data-action="click->inventory-setup#continue">
              Continue to Fill Quantities &rarr;
            </button>
          </div>
        <% end %>
      </div>

      <%# Step 2: Fill Grid (hidden initially) %>
      <div data-inventory-setup-target="step2" class="hidden">
        <div data-inventory-setup-target="gridContainer">
          <%= render Products::InventoryGridComponent.new(
            product: @product,
            storages: @storages,
            inventories: @inventories,
            subproducts: @subproducts,
            inventory_matrix: @inventory_matrix,
            bundle_breakdown: @bundle_breakdown,
            failed_cells: @failed_cells
          ) %>
        </div>
      </div>
    </div>

  <% else %>
    <%# Inventory Grid %>
    <%= render Products::InventoryGridComponent.new(
      product: @product,
      storages: @storages,
      inventories: @inventories,
      subproducts: @subproducts,
      inventory_matrix: @inventory_matrix,
      bundle_breakdown: @bundle_breakdown,
      failed_cells: @failed_cells
    ) %>
  <% end %>
</div>
