<%#
  Shared adjust inventory modal.
  Used on both storage inventory and product inventory pages.
  All fields are populated via JS (inventory_table_controller or inventory_grid_controller).
%>
<%= render Ui::ModalComponent.new(size: :md, closable: true, modal_id: "adjust-inventory-modal") do |modal| %>
  <% modal.with_header do %>
    <span id="modal-product-name">Adjust Inventory</span>
  <% end %>

  <div data-controller="inventory-form">
    <%= form_with(
      url: "#",
      scope: :inventory,
      method: :patch,
      id: "adjust-inventory-form",
      class: "space-y-5"
    ) do |f| %>
      <!-- Product & Storage Info (populated by JS) -->
      <div class="bg-gray-50 rounded-lg p-4">
        <div class="flex justify-between items-start">
          <div>
            <p class="text-sm font-medium text-gray-500">Product</p>
            <p class="mt-1 text-sm font-semibold text-gray-900" id="modal-product-sku">-</p>
            <p class="text-sm text-gray-600" id="modal-product-description">-</p>
          </div>
          <div class="text-right">
            <p class="text-sm font-medium text-gray-500">Storage</p>
            <p class="mt-1 text-sm font-semibold text-gray-900" id="modal-storage-name">-</p>
            <p class="text-sm text-gray-600" id="modal-storage-code">-</p>
          </div>
        </div>
      </div>

      <!-- Inventory Fields -->
      <div class="space-y-4">
        <div>
          <label for="inventory-value" class="block text-sm font-medium text-gray-700 mb-1.5">
            On Hand <span class="text-red-600" aria-hidden="true">*</span>
          </label>
          <%= f.number_field :value, id: "inventory-value", required: true,
              data: { inventory_form_target: "valueInput" },
              placeholder: "Current: 0",
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
          <p class="mt-1 text-xs text-gray-500">Current inventory on hand</p>
        </div>

        <div>
          <label for="eta-quantity" class="block text-sm font-medium text-gray-700 mb-1.5">ETA Quantity</label>
          <%= f.number_field :eta_quantity, id: "eta-quantity", min: 0,
              data: { inventory_form_target: "etaQuantityInput" },
              placeholder: "Current: 0",
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
          <p class="mt-1 text-xs text-gray-500">Expected incoming stock quantity</p>
        </div>

        <div>
          <label for="eta-date" class="block text-sm font-medium text-gray-700 mb-1.5">ETA Date</label>
          <%= f.date_field :eta_date, id: "eta-date",
              data: { inventory_form_target: "etaDateInput" },
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
          <p class="mt-1 text-xs text-gray-500">Expected arrival date for incoming stock</p>
        </div>
      </div>

      <!-- Available Preview -->
      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-blue-900">Total Available</p>
            <p class="text-xs text-blue-700 mt-0.5">On Hand + ETA Quantity</p>
          </div>
          <p class="text-2xl font-bold text-blue-600" data-inventory-form-target="totalAvailable">0</p>
        </div>
      </div>

      <!-- Reason -->
      <div>
        <label for="adjustment-reason" class="block text-sm font-medium text-gray-700 mb-1.5">Reason (Optional)</label>
        <%= f.text_area :reason, id: "adjustment-reason", rows: 3,
            placeholder: "Enter reason for this adjustment (e.g., stock count, damaged goods, new shipment, etc.)",
            class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
      </div>

      <!-- Actions -->
      <div class="flex justify-end gap-2 pt-4">
        <%= render Ui::ButtonComponent.new(variant: :secondary, data: { action: "click->modal#close" }) do %>
          Cancel
        <% end %>
        <%= render Ui::ButtonComponent.new(variant: :primary, type: "submit") do %>
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Save Changes
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
