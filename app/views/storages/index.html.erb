<% content_for :page_header do %>
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Storage Locations</h1>
      <p class="mt-2 text-sm text-gray-700">
        Manage warehouse storage locations and track inventory across your facilities
      </p>
    </div>
    <div class="flex gap-3">
      <%= render Ui::ButtonComponent.new(
        variant: :primary,
        onclick: "window.location.href='#{new_storage_path}'"
      ) do %>
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        New Storage Location
      <% end %>
    </div>
  </div>
<% end %>

<div class="space-y-6">
  <% if @storages.any? %>
    <!-- Storage Grid -->
    <div id="storages-grid" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <%= render partial: "storage_card", collection: @storages, as: :storage %>
    </div>
  <% else %>
    <%= render "empty_state" %>
  <% end %>
</div>
