<%= render Ui::CardComponent.new(padding: :none) do %>
  <div class="px-4 py-6 sm:p-8">
    <%= form_with(model: storage, class: "space-y-6") do |f| %>
      <!-- Error Display -->
      <% if storage.errors.any? %>
        <div class="rounded-md bg-red-50 p-4 border border-red-200">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-800">
                <%= pluralize(storage.errors.count, "error") %> prohibited this storage from being saved:
              </h3>
              <div class="mt-2 text-sm text-red-700">
                <ul role="list" class="list-disc space-y-1 pl-5">
                  <% storage.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Form Fields -->
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <!-- Name Field -->
        <div class="sm:col-span-2">
          <%= f.label :name, class: "block text-sm font-medium text-gray-700" do %>
            Name
            <span class="text-red-600" aria-hidden="true">*</span>
            <span class="sr-only">(required)</span>
          <% end %>
          <%= f.text_field :name,
                required: true,
                aria: { required: "true" },
                class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm #{'border-red-300' if storage.errors[:name].any?}",
                placeholder: "e.g., Main Warehouse" %>
          <% if storage.errors[:name].any? %>
            <p class="mt-2 text-sm text-red-600" role="alert">
              <%= storage.errors[:name].first %>
            </p>
          <% end %>
        </div>

        <!-- Code Field -->
        <div>
          <%= f.label :code, class: "block text-sm font-medium text-gray-700" do %>
            Code
            <span class="text-red-600" aria-hidden="true">*</span>
            <span class="sr-only">(required)</span>
          <% end %>
          <%= f.text_field :code,
                required: true,
                aria: { required: "true" },
                class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm uppercase #{'border-red-300' if storage.errors[:code].any?}",
                placeholder: "e.g., WH-MAIN",
                pattern: "[A-Z0-9-]+",
                title: "Use uppercase letters, numbers, and hyphens only",
                onkeyup: "this.value = this.value.toUpperCase()" %>
          <p class="mt-1 text-sm text-gray-500">
            Unique identifier (uppercase letters, numbers, and hyphens)
          </p>
          <% if storage.errors[:code].any? %>
            <p class="mt-2 text-sm text-red-600" role="alert">
              <%= storage.errors[:code].first %>
            </p>
          <% end %>
        </div>

        <!-- Storage Type Field -->
        <div>
          <%= f.label :storage_type, class: "block text-sm font-medium text-gray-700" do %>
            Storage Type
            <span class="text-red-600" aria-hidden="true">*</span>
            <span class="sr-only">(required)</span>
          <% end %>
          <%= f.select :storage_type,
                options_for_select([
                  ['Regular', 'regular'],
                  ['Temporary', 'temporary'],
                  ['Incoming', 'incoming']
                ], storage.storage_type),
                {},
                required: true,
                aria: { required: "true" },
                class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm #{'border-red-300' if storage.errors[:storage_type].any?}" %>
          <p class="mt-1 text-sm text-gray-500">
            Type of storage location
          </p>
          <% if storage.errors[:storage_type].any? %>
            <p class="mt-2 text-sm text-red-600" role="alert">
              <%= storage.errors[:storage_type].first %>
            </p>
          <% end %>
        </div>

        <!-- Storage Status Field -->
        <div>
          <%= f.label :storage_status, class: "block text-sm font-medium text-gray-700" do %>
            Storage Status
            <span class="text-red-600" aria-hidden="true">*</span>
            <span class="sr-only">(required)</span>
          <% end %>
          <%= f.select :storage_status,
                options_for_select([
                  ['Active', 'active'],
                  ['Deleted', 'deleted']
                ], storage.storage_status || 'active'),
                {},
                required: true,
                aria: { required: "true" },
                class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm #{'border-red-300' if storage.errors[:storage_status].any?}" %>
          <p class="mt-1 text-sm text-gray-500">
            Current status of this storage location
          </p>
          <% if storage.errors[:storage_status].any? %>
            <p class="mt-2 text-sm text-red-600" role="alert">
              <%= storage.errors[:storage_status].first %>
            </p>
          <% end %>
        </div>

        <!-- Storage Position Field -->
        <div>
          <%= f.label :storage_position, class: "block text-sm font-medium text-gray-700" do %>
            Storage Position
          <% end %>
          <%= f.number_field :storage_position,
                class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
                placeholder: "0",
                min: 0 %>
          <p class="mt-1 text-sm text-gray-500">
            Display order or physical position (optional)
          </p>
        </div>

        <!-- Default Checkbox -->
        <div class="flex items-start sm:col-span-2">
          <div class="flex items-center h-5">
            <%= f.check_box :default,
                  class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500",
                  id: "storage_default" %>
          </div>
          <div class="ml-3 text-sm">
            <%= f.label :default, class: "font-medium text-gray-700", for: "storage_default" do %>
              Default Storage Location
            <% end %>
            <p class="text-gray-500">
              Mark this as the default storage location for new inventory
            </p>
          </div>
        </div>
      </div>

      <!-- Form Actions -->
      <div class="flex items-center justify-end gap-3 pt-4 border-t border-gray-200">
        <%= link_to storages_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
          Cancel
        <% end %>

        <%= render Ui::ButtonComponent.new(
          type: "submit",
          variant: :primary
        ) do %>
          <%= storage.persisted? ? 'Update Storage Location' : 'Create Storage Location' %>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
