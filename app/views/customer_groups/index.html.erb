<% content_for :page_header do %>
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Customer Groups</h1>
      <p class="mt-2 text-sm text-gray-700">
        Manage customer groups for targeted pricing and discounts
      </p>
    </div>
    <div>
      <%= link_to new_customer_group_path do %>
        <%= render Ui::ButtonComponent.new(variant: :primary) do %>
          <svg class="h-5 w-5 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          New Customer Group
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<% if @customer_groups.any? %>
  <%= render Ui::CardComponent.new(padding: :none) do %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Name
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Code
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Discount
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Created
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
              Actions
            </th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @customer_groups.each do |group| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900">
                  <%= group.name %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900">
                  <%= render Ui::BadgeComponent.new(variant: :gray) do %>
                    <%= group.code %>
                  <% end %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% if group.discount_percent.present? && group.discount_percent > 0 %>
                  <%= render Ui::BadgeComponent.new(variant: :success) do %>
                    <%= number_to_percentage(group.discount_percent, precision: 0) %> off
                  <% end %>
                <% else %>
                  <span class="text-sm text-gray-500">-</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= group.created_at.strftime("%b %d, %Y") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <div class="flex items-center justify-end gap-2">
                  <%= link_to edit_customer_group_path(group) do %>
                    <%= render Ui::ButtonComponent.new(variant: :ghost, size: :sm, aria_label: "Edit #{group.name}") do %>
                      <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                      </svg>
                    <% end %>
                  <% end %>
                  <%= button_to customer_group_path(group), method: :delete, form: { data: { turbo_confirm: "Are you sure you want to delete this customer group? All associated prices will also be removed." } } do %>
                    <%= render Ui::ButtonComponent.new(variant: :ghost, size: :sm, aria_label: "Delete #{group.name}") do %>
                      <svg class="h-4 w-4 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <!-- Pagination -->
  <% if @pagy %>
    <div class="mt-6">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
<% else %>
  <!-- Empty State -->
  <%= render Shared::EmptyStateComponent.new(
    title: "No customer groups",
    description: "Get started by creating your first customer group for targeted pricing",
    icon: :users
  ) do %>
    <%= link_to new_customer_group_path do %>
      <%= render Ui::ButtonComponent.new(variant: :primary) do %>
        <svg class="h-5 w-5 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Create Customer Group
      <% end %>
    <% end %>
  <% end %>
<% end %>
