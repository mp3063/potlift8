<% content_for :page_header do %>
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @customer_group.name %></h1>
      <p class="mt-2 text-sm text-gray-700">
        <%= @customer_group.code %>
      </p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to edit_customer_group_path(@customer_group) do %>
        <%= render Ui::ButtonComponent.new(variant: :secondary) do %>
          <svg class="h-5 w-5 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
          Edit
        <% end %>
      <% end %>
      <%= link_to customer_groups_path do %>
        <%= render Ui::ButtonComponent.new(variant: :ghost) do %>
          <svg class="h-5 w-5 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<!-- Stats Cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
  <!-- Discount Card -->
  <%= render Ui::CardComponent.new do %>
    <h3 class="text-sm font-medium text-gray-500 mb-2">Group Discount</h3>
    <p class="text-3xl font-bold text-blue-600">
      <%= number_to_percentage(@customer_group.discount_percentage, precision: 2) %>
    </p>
    <p class="text-xs text-gray-500 mt-1">Applied to base prices</p>
  <% end %>

  <!-- Products Count -->
  <%= render Ui::CardComponent.new do %>
    <h3 class="text-sm font-medium text-gray-500 mb-2">Products with Pricing</h3>
    <p class="text-3xl font-bold text-gray-900"><%= @products_count %></p>
    <p class="text-xs text-gray-500 mt-1">
      <%= @products_count == 1 ? 'product' : 'products' %> with custom pricing
    </p>
  <% end %>

  <!-- Active Status -->
  <%= render Ui::CardComponent.new do %>
    <h3 class="text-sm font-medium text-gray-500 mb-2">Status</h3>
    <div class="mt-2">
      <%= render Ui::BadgeComponent.new(variant: @customer_group.active? ? :success : :gray, dot: true) do %>
        <%= @customer_group.active? ? 'Active' : 'Inactive' %>
      <% end %>
    </div>
    <p class="text-xs text-gray-500 mt-1">
      <%= @customer_group.active? ? 'Group is active' : 'Group is inactive' %>
    </p>
  <% end %>
</div>

<!-- Products with Group Pricing -->
<% if @products_count > 0 %>
  <%= render Ui::CardComponent.new(padding: :none) do |card| %>
    <% card.with_header do %>
      <div class="flex items-center justify-between">
        <h2 class="text-lg font-semibold">Products with Group Pricing</h2>
        <%= render Ui::BadgeComponent.new(variant: :gray) do %>
          <%= @products_count %> <%= @products_count == 1 ? 'product' : 'products' %>
        <% end %>
      </div>
    <% end %>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Product
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              SKU
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Price
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Currency
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
              Actions
            </th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @customer_group.prices.includes(:product).each do |price| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900">
                  <%= link_to price.product.name, product_path(price.product), class: "text-blue-600 hover:text-blue-800" %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-500">
                  <%= render Ui::BadgeComponent.new(variant: :gray) do %>
                    <%= price.product.sku %>
                  <% end %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-blue-600">
                  <%= number_to_currency(price.value, unit: '') %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-500">
                  <%= render Ui::BadgeComponent.new(variant: :gray) do %>
                    <%= price.currency %>
                  <% end %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to product_path(price.product) do %>
                  <%= render Ui::ButtonComponent.new(variant: :ghost, size: :sm, aria_label: "View #{price.product.name}") do %>
                    View Product
                  <% end %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
<% else %>
  <!-- Empty State -->
  <%= render Shared::EmptyStateComponent.new(
    title: "No products with group pricing",
    description: "This customer group doesn't have any products with custom pricing yet. Add prices in the product pricing section.",
    icon: :tag
  ) %>
<% end %>
