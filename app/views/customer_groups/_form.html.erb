<%= form_with model: @customer_group, class: "space-y-6" do |f| %>
  <!-- Form Errors -->
  <% if @customer_group.errors.any? %>
    <div class="rounded-lg bg-red-50 p-4 border border-red-200">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(@customer_group.errors.count, "error") %> prohibited this customer group from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc list-inside space-y-1">
              <% @customer_group.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Name -->
  <div>
    <label for="customer-group-name" class="block text-sm font-medium text-gray-700">
      Name <span class="text-red-600" aria-hidden="true">*</span>
      <span class="sr-only">(required)</span>
    </label>
    <%= f.text_field :name,
      id: 'customer-group-name',
      required: true,
      class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm #{'border-red-300 focus:border-red-500 focus:ring-red-500' if @customer_group.errors[:name].any?}",
      placeholder: "e.g., Wholesale Customers, VIP Members",
      'aria-required': 'true'
    %>
    <% if @customer_group.errors[:name].any? %>
      <p class="mt-2 text-sm text-red-600"><%= @customer_group.errors[:name].first %></p>
    <% else %>
      <p class="mt-2 text-sm text-gray-500">
        Enter a descriptive name for this customer group
      </p>
    <% end %>
  </div>

  <!-- Code -->
  <div>
    <label for="customer-group-code" class="block text-sm font-medium text-gray-700">
      Code <span class="text-red-600" aria-hidden="true">*</span>
      <span class="sr-only">(required)</span>
    </label>
    <%= f.text_field :code,
      id: 'customer-group-code',
      required: true,
      class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm #{'border-red-300 focus:border-red-500 focus:ring-red-500' if @customer_group.errors[:code].any?}",
      placeholder: "e.g., WHOLESALE, VIP",
      'aria-required': 'true'
    %>
    <% if @customer_group.errors[:code].any? %>
      <p class="mt-2 text-sm text-red-600"><%= @customer_group.errors[:code].first %></p>
    <% else %>
      <p class="mt-2 text-sm text-gray-500">
        Unique identifier for this group (uppercase letters, numbers, and underscores only)
      </p>
    <% end %>
  </div>

  <!-- Discount Percentage -->
  <div>
    <label for="customer-group-discount" class="block text-sm font-medium text-gray-700">
      Default Discount Percentage
    </label>
    <%= f.number_field :discount_percent,
      id: 'customer-group-discount',
      step: 0.01,
      min: 0,
      max: 100,
      class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
      placeholder: "0.00"
    %>
    <p class="mt-2 text-sm text-gray-500">
      Optional: Default discount applied to all products for this customer group (0-100%)
    </p>
  </div>

  <!-- Description (if model supports it) -->
  <% if @customer_group.respond_to?(:description) %>
    <div>
      <label for="customer-group-description" class="block text-sm font-medium text-gray-700">
        Description
      </label>
      <%= f.text_area :description,
        id: 'customer-group-description',
        rows: 3,
        class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
        placeholder: "Optional description for internal use"
      %>
    </div>
  <% end %>

  <!-- Info Box -->
  <div class="rounded-lg bg-blue-50 p-4 border border-blue-200">
    <div class="flex">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="ml-3">
        <h3 class="text-sm font-medium text-blue-800">About Customer Groups</h3>
        <div class="mt-2 text-sm text-blue-700">
          <ul class="list-disc list-inside space-y-1">
            <li>Customer groups allow you to set special pricing for specific customer segments</li>
            <li>The discount percentage is a default that can be overridden per product</li>
            <li>Use codes to reference groups in API integrations</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Form Actions -->
  <div class="flex items-center justify-end gap-3 pt-6 border-t border-gray-200">
    <%= link_to customer_groups_path do %>
      <%= render Ui::ButtonComponent.new(variant: :secondary) { "Cancel" } %>
    <% end %>
    <%= render Ui::ButtonComponent.new(type: "submit", variant: :primary) do %>
      <%= @customer_group.new_record? ? "Create Customer Group" : "Update Customer Group" %>
    <% end %>
  </div>
<% end %>
