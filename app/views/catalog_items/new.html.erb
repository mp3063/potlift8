<%= render Ui::ModalComponent.new(size: :xl, id: "add-products-modal") do |modal| %>
  <% modal.with_header do %>
    <h3 class="text-lg font-semibold text-gray-900">Add Products to <%= @catalog.name %></h3>
  <% end %>

  <%= form_with url: catalog_products_path(@catalog.code), method: :post, data: { controller: "product-selector", product_selector_target: "form" } do |f| %>
    <!-- Search and Filters -->
    <div class="mb-6 space-y-4">
      <!-- Search Bar -->
      <div class="relative">
        <%= text_field_tag :q, params[:q],
            placeholder: "Search by product name or SKU...",
            class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm",
            data: { action: "input->product-selector#search" } %>
      </div>

      <!-- Filters -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="product_type" class="block text-sm font-medium text-gray-700 mb-1">Product Type</label>
          <%= select_tag :product_type,
              options_for_select([
                ['All Types', ''],
                ['Sellable', 'sellable'],
                ['Configurable', 'configurable'],
                ['Bundle', 'bundle']
              ], params[:product_type]),
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm",
              data: { action: "change->product-selector#filter" } %>
        </div>

        <div>
          <label for="status" class="block text-sm font-medium text-gray-700 mb-1">Status</label>
          <%= select_tag :status,
              options_for_select([
                ['All Statuses', ''],
                ['Active', 'active'],
                ['Draft', 'draft'],
                ['Incoming', 'incoming']
              ], params[:status]),
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm",
              data: { action: "change->product-selector#filter" } %>
        </div>
      </div>
    </div>

    <!-- Products List -->
    <div class="mb-6">
      <% if @products.any? %>
        <!-- Select All Checkbox -->
        <div class="mb-3 flex items-center justify-between p-3 bg-gray-50 rounded-lg">
          <label class="flex items-center">
            <%= check_box_tag "select_all", "1", false,
                class: "rounded border-gray-300 text-blue-600 focus:ring-blue-500",
                data: { action: "change->product-selector#toggleAll", product_selector_target: "selectAll" } %>
            <span class="ml-2 text-sm font-medium text-gray-700">Select All (<span data-product-selector-target="count">0</span> selected)</span>
          </label>

          <span class="text-sm text-gray-600"><%= @products.count %> products available</span>
        </div>

        <!-- Product List -->
        <div class="border border-gray-200 rounded-lg divide-y divide-gray-200 max-h-96 overflow-y-auto" data-product-selector-target="list">
          <% @products.each do |product| %>
            <div class="p-4 hover:bg-gray-50 transition-colors duration-150">
              <label class="flex items-start cursor-pointer">
                <%= check_box_tag "product_ids[]", product.id, false,
                    class: "mt-0.5 rounded border-gray-300 text-blue-600 focus:ring-blue-500",
                    data: {
                      action: "change->product-selector#toggleProduct",
                      product_selector_target: "productCheckbox"
                    } %>

                <div class="ml-3 flex-1">
                  <div class="flex items-start justify-between">
                    <div>
                      <p class="text-sm font-medium text-gray-900"><%= product.name %></p>
                      <p class="text-sm text-gray-600">SKU: <%= product.sku %></p>
                    </div>

                    <div class="ml-4 flex flex-col items-end gap-1">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                        <%= product.product_type.titleize %>
                      </span>

                      <% case product.product_status %>
                      <% when "active" %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                          Active
                        </span>
                      <% when "draft" %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                          Draft
                        </span>
                      <% else %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                          <%= product.product_status.titleize %>
                        </span>
                      <% end %>
                    </div>
                  </div>

                  <% if product.labels.any? %>
                    <div class="mt-2 flex flex-wrap gap-1">
                      <% product.labels.first(3).each do |label| %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-50 text-blue-700">
                          <%= label.name %>
                        </span>
                      <% end %>
                      <% if product.labels.count > 3 %>
                        <span class="text-xs text-gray-500">+<%= product.labels.count - 3 %> more</span>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </label>
            </div>
          <% end %>
        </div>

        <!-- Pagination -->
        <% if @pagy.pages > 1 %>
          <div class="mt-4 flex items-center justify-between">
            <p class="text-sm text-gray-700">
              Showing <span class="font-medium"><%= @pagy.from %></span> to <span class="font-medium"><%= @pagy.to %></span> of <span class="font-medium"><%= @pagy.count %></span> products
            </p>

            <div class="flex gap-2">
              <% if @pagy.prev %>
                <%= link_to "Previous", catalog_new_product_path(@catalog.code, page: @pagy.prev, q: params[:q], product_type: params[:product_type], status: params[:status]),
                    class: "px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50",
                    data: { turbo_frame: "modal" } %>
              <% end %>

              <% if @pagy.next %>
                <%= link_to "Next", catalog_new_product_path(@catalog.code, page: @pagy.next, q: params[:q], product_type: params[:product_type], status: params[:status]),
                    class: "px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50",
                    data: { turbo_frame: "modal" } %>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-12 bg-gray-50 rounded-lg border-2 border-dashed border-gray-300">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
          </svg>
          <h3 class="mt-4 text-sm font-medium text-gray-900">No products found</h3>
          <p class="mt-2 text-sm text-gray-500">
            <% if params[:q].present? || params[:product_type].present? || params[:status].present? %>
              Try adjusting your filters or search criteria.
            <% else %>
              All products are already in this catalog or no products exist.
            <% end %>
          </p>
        </div>
      <% end %>
    </div>

    <% modal.with_footer do %>
      <div class="flex items-center justify-between w-full">
        <p class="text-sm text-gray-600">
          <span data-product-selector-target="selectedCount">0</span> product(s) selected
        </p>

        <div class="flex gap-3">
          <%= render Ui::ButtonComponent.new(
            variant: :secondary,
            data: { action: "click->modal#close" }
          ) do %>
            Cancel
          <% end %>

          <%= render Ui::ButtonComponent.new(
            variant: :primary,
            type: :submit,
            data: { product_selector_target: "submitButton" }
          ) do %>
            Add Selected Products
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
<% end %>
