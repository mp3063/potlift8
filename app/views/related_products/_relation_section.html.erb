<%= render Ui::CardComponent.new do |card| %>
  <% card.with_header do %>
    <div>
      <h3 class="text-lg font-semibold text-gray-900"><%= title %></h3>
      <p class="text-sm text-gray-600 mt-1"><%= description %></p>
    </div>
  <% end %>

  <% if related_products.any? %>
    <ul role="list" class="divide-y divide-gray-200">
      <% related_products.includes(:related_to).order(:position).each do |relation| %>
        <li class="flex items-center justify-between py-3">
          <div class="flex items-center min-w-0 flex-1">
            <!-- Drag Handle -->
            <div class="flex-shrink-0 cursor-move text-gray-400 hover:text-gray-600 mr-3" tabindex="0" role="button" aria-label="Drag to reorder">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16" />
              </svg>
            </div>

            <!-- Product Avatar -->
            <div class="flex-shrink-0">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-gray-500">
                <span class="text-xs font-medium leading-none text-white">
                  <%= relation.related_to.sku[0, 2].upcase %>
                </span>
              </span>
            </div>

            <!-- Product Info -->
            <div class="ml-3 flex-1 min-w-0">
              <p class="text-sm font-medium text-gray-900 truncate">
                <%= link_to relation.related_to.name, product_path(relation.related_to), class: "text-blue-600 hover:text-blue-900 hover:underline" %>
              </p>
              <p class="text-sm text-gray-500">
                SKU: <%= relation.related_to.sku %>
              </p>
            </div>

            <!-- Relation Type Badge -->
            <div class="ml-3">
              <%= render Ui::BadgeComponent.new(variant: badge_variant, size: :sm) do %>
                <%= relation_type.humanize %>
              <% end %>
            </div>
          </div>

          <!-- Remove Button -->
          <div class="ml-4 flex-shrink-0">
            <%= button_to product_related_product_path(@product, relation),
                method: :delete,
                form: { data: { turbo_confirm: "Remove this related product?" } },
                class: "text-red-600 hover:text-red-900",
                aria: { label: "Remove related product" } do %>
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>

    <!-- Add More Button -->
    <div class="mt-4 pt-4 border-t border-gray-200">
      <%= form_with model: @product.related_products.build(relation_type: relation_type), url: product_related_products_path(@product), class: "flex items-center gap-3" do |form| %>
        <%= form.hidden_field :relation_type, value: relation_type %>

        <div class="flex-1">
          <%= form.select :related_to_id,
              options_from_collection_for_select(@available_products, :id, :name),
              { prompt: "Select a product to add..." },
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
              aria: { label: "Select product to add as #{relation_type}" } %>
        </div>

        <%= render Ui::ButtonComponent.new(variant: :secondary, size: :sm, type: "submit") do %>
          <svg class="-ml-0.5 mr-1.5 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Add
        <% end %>
      <% end %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="text-center py-8">
      <svg class="mx-auto h-10 w-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
      </svg>
      <h4 class="mt-2 text-sm font-semibold text-gray-900">No <%= relation_type.humanize.downcase %> products</h4>
      <p class="mt-1 text-sm text-gray-500">Add products below</p>

      <!-- Add First Product Form -->
      <div class="mt-4">
        <%= form_with model: @product.related_products.build(relation_type: relation_type), url: product_related_products_path(@product), class: "flex items-center gap-3 max-w-md mx-auto" do |form| %>
          <%= form.hidden_field :relation_type, value: relation_type %>

          <div class="flex-1">
            <%= form.select :related_to_id,
                options_from_collection_for_select(@available_products, :id, :name),
                { prompt: "Select a product..." },
                class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
                aria: { label: "Select product to add as #{relation_type}" } %>
          </div>

          <%= render Ui::ButtonComponent.new(variant: :primary, size: :sm, type: "submit") do %>
            <svg class="-ml-0.5 mr-1.5 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Add Product
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
