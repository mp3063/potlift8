<% content_for :page_header do %>
  <nav class="flex mb-4" aria-label="Breadcrumb">
    <ol role="list" class="flex items-center space-x-4">
      <li>
        <%= link_to products_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700" do %>
          Products
        <% end %>
      </li>
      <li class="flex items-center">
        <svg class="h-5 w-5 flex-shrink-0 text-gray-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M5.555 17.776l8-16 .894.448-8 16-.894-.448z" />
        </svg>
        <%= link_to product_path(@product), class: "ml-4 text-sm font-medium text-gray-500 hover:text-gray-700" do %>
          <%= @product.name %>
        <% end %>
      </li>
      <li class="flex items-center">
        <svg class="h-5 w-5 flex-shrink-0 text-gray-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M5.555 17.776l8-16 .894.448-8 16-.894-.448z" />
        </svg>
        <span class="ml-4 text-sm font-medium text-gray-700" aria-current="page">Related Products</span>
      </li>
    </ol>
  </nav>

  <div class="flex items-center justify-between">
    <div class="min-w-0 flex-1">
      <h1 class="text-2xl font-bold text-gray-900">Related Products</h1>
      <p class="mt-2 text-sm text-gray-700">
        Manage cross-sell, upsell, and alternative product relationships
      </p>
    </div>
  </div>
<% end %>

<div class="space-y-6">
  <!-- Cross-Sell Products -->
  <%= render 'relation_section',
    title: 'Cross-Sell Products',
    description: 'Products frequently bought together with this product',
    relation_type: 'cross_sell',
    related_products: @product.related_products.cross_sell,
    badge_variant: :info %>

  <!-- Upsell Products -->
  <%= render 'relation_section',
    title: 'Upsell Products',
    description: 'Higher-value alternatives to this product',
    relation_type: 'upsell',
    related_products: @product.related_products.upsell,
    badge_variant: :success %>

  <!-- Alternative Products -->
  <%= render 'relation_section',
    title: 'Alternative Products',
    description: 'Similar products that can be offered as alternatives',
    relation_type: 'alternative',
    related_products: @product.related_products.alternative,
    badge_variant: :warning %>

  <!-- Accessory Products -->
  <%= render 'relation_section',
    title: 'Accessory Products',
    description: 'Products that complement or enhance this product',
    relation_type: 'accessory',
    related_products: @product.related_products.accessory,
    badge_variant: :primary %>

  <!-- Similar Products -->
  <%= render 'relation_section',
    title: 'Similar Products',
    description: 'Products with similar features or characteristics',
    relation_type: 'similar',
    related_products: @product.related_products.similar,
    badge_variant: :gray %>
</div>
