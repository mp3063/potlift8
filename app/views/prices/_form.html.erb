<%= form_with model: [@product, @price], class: "space-y-6" do |f| %>
  <!-- Form Errors -->
  <% if @price.errors.any? %>
    <div class="rounded-lg bg-red-50 p-4 border border-red-200">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(@price.errors.count, "error") %> prohibited this price from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc list-inside space-y-1">
              <% @price.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Price Type (hidden or display only) -->
  <% if @price.new_record? %>
    <%= f.hidden_field :price_type, value: params[:price_type] || 'base' %>
  <% else %>
    <div>
      <label class="block text-sm font-medium text-gray-700">Price Type</label>
      <div class="mt-1">
        <%= render Ui::BadgeComponent.new(variant: :info) do %>
          <%= @price.price_type&.titleize || "Base" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Value -->
  <div>
    <label for="price-value" class="block text-sm font-medium text-gray-700">
      Price <span class="text-red-600" aria-hidden="true">*</span>
      <span class="sr-only">(required)</span>
    </label>
    <%= f.number_field :value,
      id: 'price-value',
      step: 0.01,
      min: 0,
      required: true,
      class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm #{'border-red-300 focus:border-red-500 focus:ring-red-500' if @price.errors[:value].any?}",
      placeholder: "0.00",
      'aria-required': 'true'
    %>
    <% if @price.errors[:value].any? %>
      <p class="mt-2 text-sm text-red-600"><%= @price.errors[:value].first %></p>
    <% end %>
  </div>

  <!-- Currency -->
  <div>
    <label for="price-currency" class="block text-sm font-medium text-gray-700">
      Currency <span class="text-red-600" aria-hidden="true">*</span>
      <span class="sr-only">(required)</span>
    </label>
    <%= f.select :currency,
      options_for_select(
        [
          ['EUR', 'eur'],
          ['SEK', 'sek'],
          ['NOK', 'nok'],
          ['USD', 'usd'],
          ['GBP', 'gbp']
        ],
        @price.currency || 'eur'
      ),
      {},
      {
        id: 'price-currency',
        class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
        required: true,
        'aria-required': 'true'
      }
    %>
  </div>

  <!-- Special Price Fields -->
  <% if params[:price_type] == 'special' || @price.price_type == 'special' %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Valid From -->
      <div>
        <label for="price-valid-from" class="block text-sm font-medium text-gray-700">
          Valid From
        </label>
        <%= f.datetime_field :valid_from,
          id: 'price-valid-from',
          class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
        %>
        <p class="mt-2 text-sm text-gray-500">
          Leave empty to start immediately
        </p>
      </div>

      <!-- Valid To -->
      <div>
        <label for="price-valid-to" class="block text-sm font-medium text-gray-700">
          Valid To
        </label>
        <%= f.datetime_field :valid_to,
          id: 'price-valid-to',
          class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
        %>
        <p class="mt-2 text-sm text-gray-500">
          Leave empty for no expiration
        </p>
      </div>
    </div>
  <% end %>

  <!-- Customer Group Price Fields -->
  <% if params[:price_type] == 'group' || @price.price_type == 'group' %>
    <div>
      <label for="price-customer-group" class="block text-sm font-medium text-gray-700">
        Customer Group <span class="text-red-600" aria-hidden="true">*</span>
        <span class="sr-only">(required)</span>
      </label>
      <%= f.collection_select :customer_group_id,
        @customer_groups,
        :id,
        :name,
        { prompt: "Select a customer group" },
        {
          id: 'price-customer-group',
          class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
          required: true,
          'aria-required': 'true'
        }
      %>
    </div>

    <div>
      <p class="text-sm text-gray-500">
        Discount percentage is managed on the Customer Group record.
      </p>
    </div>
  <% end %>

  <!-- Form Actions -->
  <div class="flex items-center justify-end gap-3 pt-6 border-t border-gray-200">
    <%= link_to product_prices_path(@product) do %>
      <%= render Ui::ButtonComponent.new(variant: :secondary) { "Cancel" } %>
    <% end %>
    <%= render Ui::ButtonComponent.new(type: "submit", variant: :primary) do %>
      <%= @price.new_record? ? "Create Price" : "Update Price" %>
    <% end %>
  </div>
<% end %>
