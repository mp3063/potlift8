<% content_for :page_header do %>
  <div class="flex items-center justify-between">
    <div>
      <div class="flex items-center gap-3">
        <%= link_to product_path(@product), class: "text-gray-500 hover:text-gray-700" do %>
          <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          <span class="sr-only">Back to product</span>
        <% end %>
        <h1 class="text-2xl font-bold text-gray-900">Pricing</h1>
      </div>
      <p class="mt-2 text-sm text-gray-700">
        <%= @product.name %> (<%= @product.sku %>)
      </p>
    </div>
  </div>
<% end %>

<div class="space-y-8">
  <!-- Base Price Section -->
  <%= render Ui::CardComponent.new do |card| %>
    <% card.with_header do %>
      <h3 class="text-lg font-semibold text-gray-900">Base Price</h3>
    <% end %>

    <% if @base_price %>
      <% card.with_action do %>
        <%= link_to edit_product_price_path(@product, @base_price) do %>
          <%= render Ui::ButtonComponent.new(variant: :secondary, size: :sm) do %>
            <svg class="h-4 w-4 mr-1.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
            Edit
          <% end %>
        <% end %>
      <% end %>

      <dl class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div>
          <dt class="text-sm font-medium text-gray-500">Price</dt>
          <dd class="mt-1 text-2xl font-bold text-gray-900">
            <%= number_to_currency(@base_price.value, unit: @base_price.currency.upcase) %>
          </dd>
        </div>

        <div>
          <dt class="text-sm font-medium text-gray-500">Currency</dt>
          <dd class="mt-1 text-sm text-gray-900">
            <%= @base_price.currency.upcase %>
          </dd>
        </div>

        <div>
          <dt class="text-sm font-medium text-gray-500">Last Updated</dt>
          <dd class="mt-1 text-sm text-gray-900">
            <%= @base_price.updated_at.strftime("%B %d, %Y") %>
          </dd>
        </div>
      </dl>
    <% else %>
      <div class="text-center py-8">
        <svg class="mx-auto h-12 w-12 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="mt-2 text-sm text-gray-600">No base price set</p>
        <div class="mt-4">
          <%= link_to new_product_price_path(@product, price_type: 'base') do %>
            <%= render Ui::ButtonComponent.new(variant: :primary) do %>
              Set Base Price
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <!-- Special Prices Section -->
  <%= render Ui::CardComponent.new do |card| %>
    <% card.with_header do %>
      <h3 class="text-lg font-semibold text-gray-900">Special Prices</h3>
    <% end %>

    <% card.with_action do %>
      <%= link_to new_product_price_path(@product, price_type: 'special') do %>
        <%= render Ui::ButtonComponent.new(variant: :primary, size: :sm) do %>
          <svg class="h-4 w-4 mr-1.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Add Special Price
        <% end %>
      <% end %>
    <% end %>

    <% if @special_prices.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Price
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Valid From
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Valid To
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Status
              </th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                Actions
              </th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @special_prices.each do |price| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                  <%= number_to_currency(price.value, unit: price.currency.upcase) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= price.valid_from&.strftime("%b %d, %Y") || "-" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= price.valid_to&.strftime("%b %d, %Y") || "-" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% is_active = price.active? %>
                  <%= render Ui::BadgeComponent.new(variant: is_active ? :success : :gray, dot: true) do %>
                    <%= is_active ? "Active" : "Inactive" %>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex items-center justify-end gap-2">
                    <%= link_to edit_product_price_path(@product, price) do %>
                      <%= render Ui::ButtonComponent.new(variant: :ghost, size: :sm, aria_label: "Edit price") do %>
                        <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                      <% end %>
                    <% end %>
                    <%= button_to product_price_path(@product, price), method: :delete, form: { data: { turbo_confirm: "Are you sure you want to delete this price?" } } do %>
                      <%= render Ui::ButtonComponent.new(variant: :ghost, size: :sm, aria_label: "Delete price") do %>
                        <svg class="h-4 w-4 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-8">
        <svg class="mx-auto h-12 w-12 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
        </svg>
        <p class="mt-2 text-sm text-gray-600">No special prices configured</p>
      </div>
    <% end %>
  <% end %>

  <!-- Customer Group Prices Section -->
  <%= render Ui::CardComponent.new do |card| %>
    <% card.with_header do %>
      <h3 class="text-lg font-semibold text-gray-900">Customer Group Prices</h3>
    <% end %>

    <% card.with_action do %>
      <%= link_to new_product_price_path(@product, price_type: 'customer_group') do %>
        <%= render Ui::ButtonComponent.new(variant: :primary, size: :sm) do %>
          <svg class="h-4 w-4 mr-1.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Add Group Price
        <% end %>
      <% end %>
    <% end %>

    <% if @customer_group_prices.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Customer Group
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Price
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Discount
              </th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                Actions
              </th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @customer_group_prices.each do |price| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                  <%= price.customer_group&.name || "N/A" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= number_to_currency(price.value, unit: price.currency.upcase) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <% if price.discount_percent.present? %>
                    <%= render Ui::BadgeComponent.new(variant: :success) do %>
                      <%= number_to_percentage(price.discount_percent, precision: 0) %> off
                    <% end %>
                  <% else %>
                    -
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex items-center justify-end gap-2">
                    <%= link_to edit_product_price_path(@product, price) do %>
                      <%= render Ui::ButtonComponent.new(variant: :ghost, size: :sm, aria_label: "Edit price") do %>
                        <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                      <% end %>
                    <% end %>
                    <%= button_to product_price_path(@product, price), method: :delete, form: { data: { turbo_confirm: "Are you sure you want to delete this price?" } } do %>
                      <%= render Ui::ButtonComponent.new(variant: :ghost, size: :sm, aria_label: "Delete price") do %>
                        <svg class="h-4 w-4 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-8">
        <svg class="mx-auto h-12 w-12 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        <p class="mt-2 text-sm text-gray-600">No customer group prices configured</p>
      </div>
    <% end %>
  <% end %>
</div>
