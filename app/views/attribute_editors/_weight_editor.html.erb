<div class="flex gap-x-2">
  <%= form.number_field :value,
      value: value&.value,
      step: "0.001",
      min: "0",
      placeholder: "0.000",
      class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6" %>
  <%= form.select :unit,
      options_for_select([['kg', 'kg'], ['g', 'g'], ['lb', 'lb'], ['oz', 'oz']], value&.unit || 'kg'),
      {},
      class: "block rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6" %>
</div>
