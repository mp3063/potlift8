<div class="space-y-3">
  <p class="text-sm font-medium text-gray-700">Customer Group Prices</p>

  <div>
    <label class="block text-xs font-medium text-gray-600 mb-1">Default Price (cents)</label>
    <%= form.number_field :value,
        value: value&.value,
        step: "1",
        min: "0",
        placeholder: "0",
        class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6" %>
  </div>

  <p class="mt-2 text-xs text-gray-500">
    Note: Full customer group pricing requires JavaScript component. Contact developer for group-specific pricing.
  </p>
</div>
