<div class="space-y-1">
  <div class="relative rounded-md shadow-sm">
    <%= form.number_field :value,
        value: value&.value,
        step: "1",
        min: "0",
        placeholder: "0",
        class: "block w-full rounded-md border-0 py-1.5 pr-12 text-gray-900 ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6",
        'aria-label': "Price in cents for #{attribute.name}" %>
    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
      <span class="text-gray-500 sm:text-sm">cents</span>
    </div>
  </div>
  <p class="text-xs text-gray-500">Enter price in cents (e.g., 1999 = €19.99)</p>
</div>
