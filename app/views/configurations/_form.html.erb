<%= form_with(model: configuration, url: configuration.persisted? ? product_configuration_path(@product, configuration) : product_configurations_path(@product), data: { controller: "configuration-form" }) do |form| %>
  <% if configuration.errors.any? %>
    <%= render Shared::FormErrorsComponent.new(errors: configuration.errors) %>
  <% end %>

  <%= render Ui::CardComponent.new do |card| %>
    <% card.with_header do %>
      <h3 class="text-lg font-semibold text-gray-900">Configuration Details</h3>
    <% end %>

    <div class="space-y-6">
      <!-- Name Field -->
      <div>
        <%= form.label :name, "Configuration Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <p class="text-xs text-gray-500 mb-2">
          Examples: Size, Color, Material, Style
        </p>
        <%= form.text_field :name,
          class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
          placeholder: "e.g., Size",
          required: true,
          aria: { required: true } %>
      </div>

      <!-- Code Field -->
      <div>
        <%= form.label :code, "Configuration Code", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <p class="text-xs text-gray-500 mb-2">
          Unique identifier (lowercase, no spaces). Examples: size, color, material
        </p>
        <%= form.text_field :code,
          class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
          placeholder: "e.g., size",
          required: true,
          pattern: "[a-z_]+",
          aria: { required: true, describedby: "code-help" } %>
        <p id="code-help" class="mt-1 text-xs text-gray-500">
          Must be lowercase letters and underscores only
        </p>
      </div>
    </div>
  <% end %>

  <!-- Configuration Values Section -->
  <%= render Ui::CardComponent.new(class: "mt-6") do |card| %>
    <% card.with_header do %>
      <h3 class="text-lg font-semibold text-gray-900">Configuration Values</h3>
      <p class="text-sm text-gray-600 mt-1">
        Define the possible values for this configuration dimension
      </p>
    <% end %>

    <div class="space-y-4" data-configuration-form-target="container">
      <%= form.fields_for :configuration_values do |value_form| %>
        <div class="flex items-start gap-3" data-value-field data-value-id="<%= value_form.object.id || 'new' %>">
          <!-- Drag Handle -->
          <div class="flex-shrink-0 pt-2 cursor-move text-gray-400 hover:text-gray-600" tabindex="0" role="button" aria-label="Drag to reorder">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16" />
            </svg>
          </div>

          <!-- Value Input -->
          <div class="flex-1">
            <%= value_form.label :value, "Value", class: "sr-only" %>
            <%= value_form.text_field :value,
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
              placeholder: "e.g., Small, Medium, Large",
              required: true,
              aria: { label: "Configuration value" } %>
          </div>

          <!-- Position (hidden) -->
          <%= value_form.hidden_field :position %>

          <!-- Destroy Flag (hidden) -->
          <%= value_form.hidden_field :_destroy, value: '0' %>

          <!-- Remove Button -->
          <div class="flex-shrink-0 pt-1">
            <%= render Ui::ButtonComponent.new(
              variant: :ghost,
              size: :sm,
              type: "button",
              aria_label: "Remove value",
              data: { action: "click->configuration-form#removeValue" }
            ) do %>
              <svg class="h-5 w-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Add Value Button -->
    <div class="mt-4">
      <%= render Ui::ButtonComponent.new(
        variant: :secondary,
        size: :sm,
        type: "button",
        data: { action: "click->configuration-form#addValue" }
      ) do %>
        <svg class="-ml-0.5 mr-1.5 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Add Value
      <% end %>
    </div>
  <% end %>

  <!-- Hidden Template for New Values -->
  <template data-configuration-form-target="template">
    <div class="flex items-start gap-3" data-value-field data-value-id="new">
      <!-- Drag Handle -->
      <div class="flex-shrink-0 pt-2 cursor-move text-gray-400 hover:text-gray-600" tabindex="0" role="button" aria-label="Drag to reorder">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16" />
        </svg>
      </div>

      <!-- Value Input -->
      <div class="flex-1">
        <label class="sr-only">Value</label>
        <input
          type="text"
          name="configuration[configuration_values_attributes][new_record][value]"
          id="configuration_configuration_values_attributes_new_record_value"
          class="block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
          placeholder="e.g., Small, Medium, Large"
          required
          aria-label="Configuration value"
        >
      </div>

      <!-- Position (hidden) -->
      <input type="hidden" name="configuration[configuration_values_attributes][new_record][position]" value="">

      <!-- Remove Button -->
      <div class="flex-shrink-0 pt-1">
        <%= render Ui::ButtonComponent.new(
          variant: :ghost,
          size: :sm,
          type: "button",
          aria_label: "Remove value",
          data: { action: "click->configuration-form#removeValue" }
        ) do %>
          <svg class="h-5 w-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        <% end %>
      </div>
    </div>
  </template>

  <!-- Form Actions -->
  <div class="mt-6 flex items-center justify-end gap-3">
    <%= render Ui::ButtonComponent.new(
      variant: :secondary,
      tag: :a,
      href: product_configurations_path(@product)
    ) do %>
      Cancel
    <% end %>

    <%= render Ui::ButtonComponent.new(
      variant: :primary,
      type: "submit"
    ) do %>
      <%= configuration.persisted? ? 'Update Configuration' : 'Create Configuration' %>
    <% end %>
  </div>
<% end %>
