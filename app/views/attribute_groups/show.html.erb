<div class="md:flex md:items-center md:justify-between mb-8">
  <div class="min-w-0 flex-1">
    <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-3xl sm:tracking-tight">
      <%= @attribute_group.name %>
    </h2>
    <p class="mt-1 text-sm text-gray-500">
      Code: <code class="bg-gray-100 px-2 py-1 rounded text-xs"><%= @attribute_group.code %></code>
    </p>
  </div>
  <div class="mt-4 flex md:ml-4 md:mt-0 gap-x-3">
    <%= link_to attribute_groups_path, class: "inline-flex items-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" do %>
      <svg class="-ml-0.5 mr-1.5 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      Back to Groups
    <% end %>

    <%= link_to edit_attribute_group_path(@attribute_group.code), class: "inline-flex items-center rounded-md bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-700" do %>
      <svg class="-ml-0.5 mr-1.5 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
      </svg>
      Edit
    <% end %>
  </div>
</div>

<div class="space-y-6">
  <!-- Group Details Card -->
  <div class="bg-white shadow-sm ring-1 ring-gray-900/5 sm:rounded-lg">
    <div class="px-4 py-6 sm:px-6">
      <h3 class="text-base font-semibold leading-7 text-gray-900">Group Details</h3>
      <p class="mt-1 max-w-2xl text-sm leading-6 text-gray-500">Basic information</p>
    </div>
    <div class="border-t border-gray-100">
      <dl class="divide-y divide-gray-100">
        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-900">Name</dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">
            <%= @attribute_group.name %>
          </dd>
        </div>

        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-900">Code</dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">
            <code class="bg-gray-100 px-2 py-1 rounded text-xs"><%= @attribute_group.code %></code>
          </dd>
        </div>

        <% if @attribute_group.description.present? %>
          <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-900">Description</dt>
            <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">
              <%= @attribute_group.description %>
            </dd>
          </div>
        <% end %>

        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-900">Attributes</dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">
            <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-800">
              <%= pluralize(@attribute_group.product_attributes.size, 'attribute') %>
            </span>
          </dd>
        </div>
      </dl>
    </div>
  </div>

  <!-- Attributes in This Group -->
  <% if @attribute_group.product_attributes.any? %>
    <div class="bg-white shadow-sm ring-1 ring-gray-900/5 sm:rounded-lg">
      <div class="px-4 py-6 sm:px-6">
        <h3 class="text-base font-semibold leading-7 text-gray-900">Attributes in this Group</h3>
        <p class="mt-1 max-w-2xl text-sm leading-6 text-gray-500">Ordered by position</p>
      </div>
      <div class="border-t border-gray-100">
        <ul role="list" class="divide-y divide-gray-100">
          <% @attribute_group.product_attributes.order(:attribute_position).each do |attribute| %>
            <li class="flex items-center justify-between gap-x-6 px-4 py-5 sm:px-6">
              <div class="min-w-0">
                <div class="flex items-start gap-x-3">
                  <p class="text-sm font-semibold leading-6 text-gray-900">
                    <%= link_to attribute.name, product_attribute_path(attribute.code), class: "text-blue-600 hover:text-blue-700" %>
                  </p>
                  <% if attribute.mandatory? %>
                    <span class="inline-flex items-center rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700 ring-1 ring-inset ring-red-600/10">
                      Mandatory
                    </span>
                  <% end %>
                </div>
                <div class="mt-1 flex items-center gap-x-2 text-xs leading-5 text-gray-500">
                  <p class="truncate">Code: <code class="bg-gray-100 px-1 rounded"><%= attribute.code %></code></p>
                  <svg viewBox="0 0 2 2" class="h-0.5 w-0.5 fill-current">
                    <circle cx="1" cy="1" r="1" />
                  </svg>
                  <p class="truncate">Type: <%= attribute.pa_type.to_s.gsub('patype_', '').titleize %></p>
                </div>
              </div>
              <div class="flex flex-none items-center gap-x-4">
                <span class="text-xs text-gray-500">Position <%= attribute.attribute_position %></span>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>
</div>
