<%= turbo_frame_tag "sync-status-#{catalog.code}" do %>
  <% if recent_tasks.any? || summary.present? %>
    <%# Summary stats row %>
    <% if summary.present? %>
      <div class="flex items-center gap-4 mb-4 text-sm">
        <% if summary[:total].to_i > 0 %>
          <div class="flex items-center gap-1.5">
            <span class="h-2 w-2 rounded-full bg-green-400" aria-hidden="true"></span>
            <span class="sr-only">Executed:</span>
            <span class="text-gray-700"><%= summary[:executed] || 0 %> synced</span>
          </div>
        <% end %>
        <% if (summary[:submitted].to_i + summary[:processing].to_i) > 0 %>
          <div class="flex items-center gap-1.5">
            <span class="h-2 w-2 rounded-full bg-yellow-400" aria-hidden="true"></span>
            <span class="sr-only">Pending:</span>
            <span class="text-gray-700"><%= summary[:submitted].to_i + summary[:processing].to_i %> pending</span>
          </div>
        <% end %>
        <% if failed_count > 0 %>
          <div class="flex items-center gap-1.5">
            <span class="h-2 w-2 rounded-full bg-red-400" aria-hidden="true"></span>
            <span class="sr-only">Failed:</span>
            <span class="font-medium text-red-700"><%= failed_count %> failed</span>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Recent activity feed %>
    <div>
      <h4 class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Recent Activity</h4>
      <div class="space-y-2">
        <% recent_tasks.first(5).each do |task| %>
          <div class="flex items-center justify-between py-1.5">
            <div class="flex items-center gap-2 min-w-0">
              <%# Status dot %>
              <% status_color = case task[:status].to_s
                when "executed" then "bg-green-400"
                when "processing" then "bg-yellow-400"
                when "submitted" then "bg-blue-400"
                when "failed" then "bg-red-400"
                else "bg-gray-400"
              end %>
              <span class="h-2 w-2 rounded-full flex-shrink-0 <%= status_color %>" aria-hidden="true"></span>
              <span class="sr-only"><%= task[:status] %></span>

              <%# Event type %>
              <span class="text-xs text-gray-500 flex-shrink-0"><%= task[:event_type].to_s.humanize %></span>

              <%# SKU (linked to product if available) %>
              <% sku = task[:origin_target_id] %>
              <% if sku.present? %>
                <span class="text-xs font-mono text-gray-700 truncate"><%= sku %></span>
              <% end %>
            </div>

            <div class="flex items-center gap-2 flex-shrink-0 ml-2">
              <%# Status badge %>
              <% badge_classes = case task[:status].to_s
                when "executed" then "bg-green-100 text-green-800"
                when "processing" then "bg-yellow-100 text-yellow-800"
                when "submitted" then "bg-blue-100 text-blue-800"
                when "failed" then "bg-red-100 text-red-800"
                else "bg-gray-100 text-gray-800"
              end %>
              <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium <%= badge_classes %>">
                <%= task[:status] %>
              </span>

              <%# Relative timestamp %>
              <span class="text-xs text-gray-400" title="<%= task[:created_at] %>">
                <%= time_ago_in_words(Time.parse(task[:created_at])) rescue task[:created_at] %> ago
              </span>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# View all link %>
    <div class="mt-3 pt-3 border-t border-gray-100">
      <% shopify8_url = ENV.fetch("SHOPIFY8_URL", "http://localhost:3245") %>
      <a href="<%= shopify8_url %>/dashboard/sync_tasks?shop_id=<%= catalog.shop_id %>"
         target="_blank"
         rel="noopener noreferrer"
         class="text-sm text-blue-600 hover:text-blue-800 font-medium"
         aria-label="View all sync tasks in Shopify8 (opens in new tab)">
        View all in Shopify8 &rarr;
      </a>
    </div>
  <% elsif summary.blank? && recent_tasks.empty? %>
    <%# Unable to fetch or no data %>
    <div class="text-center py-3">
      <p class="text-sm text-gray-500">Unable to fetch sync status</p>
      <button type="button"
              onclick="this.closest('turbo-frame').reload()"
              class="mt-1 text-sm text-blue-600 hover:text-blue-800 font-medium">
        Retry
      </button>
    </div>
  <% end %>
<% end %>
