<% content_for :page_header do %>
  <div class="flex items-center gap-4">
    <%= link_to edit_catalog_path(@catalog), class: "text-gray-400 hover:text-gray-600" do %>
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
    <% end %>
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Shopify Connection</h1>
      <p class="mt-1 text-sm text-gray-700">Manage Shopify integration for <%= @catalog.name %></p>
    </div>
  </div>
<% end %>

<div class="max-w-xl">
  <%= render Catalogs::ShopifyConnectionComponent.new(
    catalog: @catalog,
    connection_service: @shopify_service
  ) %>
</div>
