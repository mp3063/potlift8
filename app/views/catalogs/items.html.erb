<nav class="flex mb-6" aria-label="Breadcrumb">
  <ol class="flex items-center space-x-2 text-sm">
    <li>
      <%= link_to catalogs_path, class: "text-gray-500 hover:text-gray-700 transition-colors duration-150" do %>
        Catalogs
      <% end %>
    </li>
    <li>
      <svg class="h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
      </svg>
    </li>
    <li class="text-gray-900 font-medium">
      <%= @catalog.name %>
    </li>
  </ol>
</nav>

<% content_for :page_header do %>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= @catalog.name %></h1>
    <% if @catalog.description.present? %>
      <p class="mt-2 text-sm text-gray-700"><%= @catalog.description %></p>
    <% end %>
    <div class="mt-3 flex items-center gap-3 text-sm">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
        <%= @catalog.catalog_type.titleize %>
      </span>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 uppercase">
        <%= @catalog.currency_code %>
      </span>
      <% if @catalog.active? %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
          <span class="mr-1.5 h-1.5 w-1.5 rounded-full bg-green-400" aria-hidden="true"></span>
          Active
        </span>
      <% end %>
    </div>
  </div>

  <div class="flex flex-col sm:flex-row gap-3">
    <%= link_to catalog_new_product_path(@catalog.code), data: { turbo_frame: "modal" }, class: "inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors duration-200" do %>
      <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      Add Products
    <% end %>

    <%= link_to catalog_new_import_path(@catalog.code), data: { turbo_frame: "modal" }, class: "inline-flex items-center justify-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-lg shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors duration-200" do %>
      <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
      </svg>
      Import
    <% end %>

    <div class="relative" data-controller="dropdown">
      <button type="button" data-action="click->dropdown#toggle" data-dropdown-target="button" class="inline-flex items-center justify-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-lg shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors duration-200" aria-expanded="false" aria-haspopup="true">
        <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
        </svg>
        Export
        <svg class="ml-2 -mr-1 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>

      <div data-dropdown-target="menu" class="hidden absolute right-0 z-10 mt-2 w-48 rounded-lg shadow-lg bg-white ring-1 ring-black ring-opacity-5 transition-all duration-200 starting:opacity-0 starting:scale-95" role="menu" aria-orientation="vertical">
        <div class="py-1">
          <%= link_to export_catalog_path(@catalog.code, format: :csv), class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors duration-150", role: "menuitem" do %>
            <div class="flex items-center">
              <svg class="mr-3 h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Export as CSV
            </div>
          <% end %>
          <%= link_to export_catalog_path(@catalog.code, format: :json), class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors duration-150", role: "menuitem" do %>
            <div class="flex items-center">
              <svg class="mr-3 h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
              Export as JSON
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<% if @catalog.shopify_connected? && @sync_counts %>
  <div class="mb-6 bg-white shadow-sm rounded-lg border border-gray-200 p-4">
    <div class="flex flex-col lg:flex-row items-start lg:items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <svg class="h-6 w-6 text-green-600 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M15.337 3.415c-.25-.163-.565-.108-.752.126l-2.064 2.626c-.022.028-.053.04-.077.063l-.012-.003-1.014-3.04c-.085-.256-.35-.417-.614-.376C8.397 3.198 6.5 5.2 6.5 7.63c0 .147.03.286.042.43l-3.72 1.14c-.211.065-.323.188-.34.374-.017.187.07.33.26.44l3.684 2.126-.092.085c-1.57 1.47-2.584 3.556-2.584 5.862 0 .093.013.182.017.274a.425.425 0 00.128.276c.076.072.178.113.284.113h.068l3.458-.46c.56 1.37 1.52 2.55 2.71 3.42l-.4 2.35c-.04.22.09.43.3.49.06.02.12.02.18.02.16 0 .31-.09.38-.24l1.38-2.72c.62.17 1.27.28 1.94.28s1.32-.11 1.94-.28l1.38 2.72c.07.15.22.24.38.24.06 0 .12-.01.18-.02.21-.06.34-.27.3-.49l-.4-2.35c1.19-.87 2.15-2.05 2.71-3.42l3.46.46h.07c.11 0 .21-.04.28-.11a.425.425 0 00.13-.28c0-.09.02-.18.02-.27 0-2.31-1.01-4.39-2.58-5.86l-.1-.09 3.69-2.13c.19-.11.27-.25.26-.44-.02-.19-.13-.31-.34-.37l-3.72-1.14c.01-.15.04-.29.04-.43 0-2.27-1.66-4.18-3.87-4.72z"/>
        </svg>
        <div>
          <div class="flex items-center gap-2">
            <h3 class="text-sm font-semibold text-gray-900">Shopify Sync</h3>
            <% if @catalog.info&.dig("sync_paused") %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                <svg class="mr-1 h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Paused
              </span>
            <% end %>
          </div>
          <p class="text-xs text-gray-500">
            Connected to <span class="font-mono"><%= @catalog.shopify_domain || "Shopify" %></span>
          </p>
        </div>
      </div>

      <div class="flex items-center gap-6 text-sm">
        <div class="text-center">
          <div class="text-lg font-semibold text-green-600"><%= @sync_counts[:synced] %></div>
          <div class="text-xs text-gray-500">Synced</div>
        </div>
        <div class="text-center">
          <div class="text-lg font-semibold text-yellow-600"><%= @sync_counts[:outdated] %></div>
          <div class="text-xs text-gray-500">Outdated</div>
        </div>
        <div class="text-center">
          <div class="text-lg font-semibold text-red-600"><%= @sync_counts[:failed] %></div>
          <div class="text-xs text-gray-500">Failed</div>
        </div>
        <div class="text-center">
          <div class="text-lg font-semibold text-gray-400"><%= @sync_counts[:never] %></div>
          <div class="text-xs text-gray-500">Never synced</div>
        </div>
      </div>

      <div class="flex items-center gap-2">
        <%= button_to sync_all_catalog_path(@catalog.code),
            method: :post,
            class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors duration-200",
            data: { turbo_confirm: "Sync all #{@catalog.catalog_items.count} products to Shopify?", disable_with: "Syncing..." } do %>
          <svg class="-ml-1 mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          Sync All
        <% end %>

        <%= button_to toggle_sync_pause_catalog_path(@catalog.code),
            method: :post,
            class: "inline-flex items-center justify-center px-3 py-2 border border-gray-300 text-sm font-medium rounded-lg shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors duration-200",
            title: @catalog.info&.dig("sync_paused") ? "Resume auto-sync" : "Pause auto-sync" do %>
          <% if @catalog.info&.dig("sync_paused") %>
            <svg class="h-5 w-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          <% else %>
            <svg class="h-5 w-5 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<% if @catalog.shopify_connected? && @catalog.info&.dig("sync_paused") %>
  <div class="rounded-lg bg-yellow-50 border border-yellow-200 p-4 mb-6">
    <div class="flex">
      <svg class="h-5 w-5 text-yellow-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
      <div class="ml-3">
        <h3 class="text-sm font-medium text-yellow-800">Auto-sync is paused</h3>
        <p class="mt-1 text-sm text-yellow-700">
          Product changes are not being sent to Shopify. Resume sync to start propagating changes again.
        </p>
        <div class="mt-3">
          <%= button_to toggle_sync_pause_catalog_path(@catalog),
              method: :post,
              class: "inline-flex items-center px-3 py-1.5 border border-yellow-400 text-xs font-medium rounded-md text-yellow-800 bg-yellow-100 hover:bg-yellow-200 transition-colors duration-150" do %>
            Resume Sync
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<% if @catalog_items.any? %>
  <!-- Search Bar -->
  <div class="mb-6">
    <%= form_with url: catalog_items_path(@catalog), method: :get, class: "flex gap-3" do |form| %>
      <%= render Ui::SearchInputComponent.new(
        name: :q,
        value: params[:q],
        placeholder: "Search by product name or SKU...",
        label: "Search products in catalog"
      ) %>
      <% if params[:q].present? %>
        <%= link_to catalog_items_path(@catalog), class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
          Clear
        <% end %>
      <% end %>
    <% end %>
  </div>

  <!-- Items Table -->
  <div class="bg-white shadow-sm rounded-lg border border-gray-200 overflow-hidden"
       data-controller="catalog-items"
       data-catalog-items-catalog-id-value="<%= @catalog.id %>">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="w-10 px-3 py-3">
              <span class="sr-only">Reorder</span>
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Priority
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              SKU
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Product Name
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Type
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              State
            </th>
            <% if @catalog.shopify_connected? %>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Shopify
              </th>
            <% end %>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Overrides
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
              Actions
            </th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200" data-catalog-items-target="items">
          <% @catalog_items.each do |catalog_item| %>
            <tr id="catalog_item_<%= catalog_item.id %>" class="hover:bg-gray-50 transition-colors duration-150 group" data-catalog-items-target="item" data-id="<%= catalog_item.id %>">
              <td class="px-3 py-4 whitespace-nowrap">
                <button type="button" class="cursor-move text-gray-400 hover:text-gray-600 opacity-0 group-hover:opacity-100 transition-opacity duration-150 focus:opacity-100" aria-label="Drag to reorder" data-catalog-items-target="handle">
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                  </svg>
                </button>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <turbo-frame id="catalog_item_<%= catalog_item.id %>_priority" class="inline-block">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
                    <%= catalog_item.priority %>
                  </span>
                </turbo-frame>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to catalog_item.product.sku, product_path(catalog_item.product), class: "text-sm font-medium text-blue-600 hover:text-blue-900 transition-colors duration-150" %>
              </td>
              <td class="px-6 py-4">
                <div class="text-sm text-gray-900"><%= catalog_item.product.name %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                  <%= catalog_item.product.product_type.titleize %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% case catalog_item.catalog_item_state %>
                <% when "active" %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    <span class="mr-1.5 h-1.5 w-1.5 rounded-full bg-green-400" aria-hidden="true"></span>
                    Active
                  </span>
                <% when "inactive" %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                    Inactive
                  </span>
                <% when "discontinued" %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                    Discontinued
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                    <%= catalog_item.catalog_item_state.titleize %>
                  </span>
                <% end %>
              </td>
              <% if @catalog.shopify_connected? %>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center gap-2">
                    <%= sync_status_badge_for(catalog_item) %>
                    <% if catalog_item.last_synced_at %>
                      <span class="text-xs text-gray-400 hidden sm:inline" title="<%= catalog_item.last_synced_at.strftime('%B %d, %Y at %I:%M %p') %>">
                        <%= time_ago_in_words(catalog_item.last_synced_at) %>
                      </span>
                    <% end %>
                  </div>
                  <% if catalog_item.sync_failed? && catalog_item.last_sync_error.present? %>
                    <p class="text-xs text-red-500 mt-1 max-w-[200px] truncate" title="<%= catalog_item.last_sync_error %>">
                      <%= catalog_item.last_sync_error %>
                    </p>
                  <% end %>
                </td>
              <% end %>
              <td class="px-6 py-4 whitespace-nowrap">
                <% override_count = catalog_item.catalog_item_attribute_values.count %>
                <% if override_count > 0 %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800" title="<%= override_count %> attribute override(s)">
                    <%= override_count %> override<%= 's' if override_count != 1 %>
                  </span>
                <% else %>
                  <span class="text-sm text-gray-400">None</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <div class="flex items-center justify-end gap-3">
                  <% if @catalog.shopify_connected? %>
                    <%= button_to sync_product_catalog_path(@catalog.code, catalog_item.product.id),
                        method: :post,
                        class: "text-green-600 hover:text-green-900 transition-colors duration-150",
                        title: "Sync to Shopify",
                        data: { disable_with: "..." } do %>
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                      </svg>
                    <% end %>
                  <% end %>
                  <%= link_to edit_product_path(catalog_item.product), class: "text-blue-600 hover:text-blue-900 transition-colors duration-150", title: "Edit product" do %>
                    Edit
                  <% end %>
                  <%= button_to catalog_item_path(@catalog.code, catalog_item.product.id), method: :delete, data: { turbo_confirm: "Remove this product from the catalog?" }, class: "text-red-600 hover:text-red-900 transition-colors duration-150", title: "Remove from catalog" do %>
                    Remove
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <% if @catalog_items.respond_to?(:total_pages) && @catalog_items.total_pages > 1 %>
    <div class="mt-6">
      <%= render "shared/pagination", pagy: @pagy %>
    </div>
  <% end %>
<% else %>
  <div class="text-center py-12 bg-white rounded-lg border border-gray-200 shadow-sm">
    <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
    </svg>
    <h3 class="mt-4 text-sm font-medium text-gray-900">No products in catalog</h3>
    <p class="mt-2 text-sm text-gray-500">Get started by adding products to this catalog.</p>
    <div class="mt-6">
      <%= link_to catalog_new_product_path(@catalog.code), data: { turbo_frame: "modal" }, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors duration-200" do %>
        <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Add Products
      <% end %>
    </div>
  </div>
<% end %>
