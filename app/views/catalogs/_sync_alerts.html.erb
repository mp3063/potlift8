<%= turbo_frame_tag "sync-alerts-#{catalog.code}" do %>
  <% if failed_count > 0 %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4 mb-6" role="alert">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <svg class="h-5 w-5 text-red-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <p class="ml-3 text-sm font-medium text-red-800">
            <%= pluralize(failed_count, "sync task") %> failed for this catalog
          </p>
        </div>
        <% shopify8_url = ENV.fetch("SHOPIFY8_URL", "http://localhost:3245") %>
        <a href="<%= shopify8_url %>/dashboard/sync_tasks?shop_id=<%= catalog.shop_id %>&status=failed"
           target="_blank"
           rel="noopener noreferrer"
           class="text-sm font-medium text-red-700 hover:text-red-900 underline flex-shrink-0 ml-4"
           aria-label="View failed sync tasks in Shopify8 (opens in new tab)">
          View Details &rarr;
        </a>
      </div>
    </div>
  <% end %>
<% end %>
