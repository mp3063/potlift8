<%= turbo_frame_tag "modal" do %>
  <%= render Ui::ModalComponent.new(size: :xl, closable: true) do |modal| %>
    <% modal.with_header do %>
      Add Products to <%= @storage.name %>
    <% end %>

    <div data-controller="product-selector">
      <!-- Search and Filters -->
      <div class="mb-6 space-y-4">
        <%= form_with url: new_storage_inventory_path(@storage), method: :get, data: { turbo_frame: "modal", action: "submit->product-selector#handleSearch" } do |f| %>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <!-- Search Input -->
            <div class="md:col-span-2">
              <%= f.label :search, "Search by SKU or Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :search,
                  value: params[:search],
                  placeholder: "Enter SKU or product name...",
                  class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
            </div>

            <!-- Product Type Filter -->
            <div>
              <%= f.label :product_type, "Product Type", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.select :product_type,
                  options_for_select([
                    ["All Types", ""],
                    ["Sellable", "1"],
                    ["Configurable", "2"],
                    ["Bundle", "3"]
                  ], params[:product_type]),
                  {},
                  class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500",
                  data: { action: "change->product-selector#handleSearch" } %>
            </div>
          </div>

          <!-- Label Filter -->
          <% if @labels.any? %>
            <div>
              <%= f.label :label_id, "Filter by Label", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.select :label_id,
                  options_for_select([["All Labels", ""]] + @labels.map { |l| [l.name, l.id] }, params[:label_id]),
                  {},
                  class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500",
                  data: { action: "change->product-selector#handleSearch" } %>
            </div>
          <% end %>

          <noscript>
            <%= f.submit "Search", class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700" %>
          </noscript>
        <% end %>
      </div>

      <!-- Product Selection Form -->
      <%= form_with url: storage_inventories_path(@storage), method: :post, html: { id: "add-products-form" }, data: { product_selector_target: "form" } do |f| %>
        <% if @available_products.any? %>
          <!-- Selection Controls -->
          <div class="mb-4 flex items-center justify-between bg-gray-50 p-3 rounded-lg">
            <div class="flex items-center gap-4">
              <%= render Ui::ButtonComponent.new(
                variant: :ghost,
                size: :sm,
                type: "button",
                data: { action: "click->product-selector#selectAll" }
              ) do %>
                Select All
              <% end %>
              <%= render Ui::ButtonComponent.new(
                variant: :ghost,
                size: :sm,
                type: "button",
                data: { action: "click->product-selector#deselectAll" }
              ) do %>
                Deselect All
              <% end %>
            </div>
            <div class="text-sm text-gray-600">
              <span data-product-selector-target="selectedCount">0</span> products selected
            </div>
          </div>

          <!-- Products Table -->
          <div class="border border-gray-200 rounded-lg overflow-hidden max-h-96 overflow-y-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50 sticky top-0">
                <tr>
                  <th scope="col" class="w-12 px-4 py-3 text-left">
                    <span class="sr-only">Select</span>
                  </th>
                  <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    SKU
                  </th>
                  <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Product Name
                  </th>
                  <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Type
                  </th>
                  <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Initial Quantity
                  </th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200" data-product-selector-target="productList">
                <% @available_products.each do |product| %>
                  <tr class="hover:bg-gray-50 transition-colors" data-product-selector-target="productRow">
                    <td class="px-4 py-3 whitespace-nowrap">
                      <%= check_box_tag "product_ids[]",
                          product.id,
                          false,
                          class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500",
                          data: {
                            product_selector_target: "checkbox",
                            action: "change->product-selector#updateCount"
                          } %>
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap text-sm font-medium text-gray-900">
                      <%= product.sku %>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-900">
                      <%= product.name %>
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap">
                      <%= render Ui::BadgeComponent.new(variant: :gray, size: :sm) do %>
                        <%= product.product_type_before_type_cast == 1 ? 'Sellable' : product.product_type_before_type_cast == 2 ? 'Configurable' : 'Bundle' %>
                      <% end %>
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap text-right">
                      <%= number_field_tag "quantities[#{product.id}]",
                          0,
                          min: 0,
                          step: 1,
                          class: "w-24 rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-right text-sm",
                          placeholder: "0" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <% if @available_products.count >= 100 %>
            <div class="mt-2 text-sm text-gray-500">
              Showing first 100 results. Use search to narrow down products.
            </div>
          <% end %>
        <% else %>
          <!-- Empty State -->
          <div class="text-center py-12 bg-gray-50 rounded-lg">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
            </svg>
            <h3 class="mt-2 text-sm font-semibold text-gray-900">
              <%= params[:search].present? ? "No products found" : "All products already in storage" %>
            </h3>
            <p class="mt-1 text-sm text-gray-500">
              <%= params[:search].present? ? "Try a different search term or filter." : "This storage already contains all active products." %>
            </p>
          </div>
        <% end %>

        <% modal.with_footer do %>
          <%= render Ui::ButtonComponent.new(
            variant: :secondary,
            data: { action: "click->modal#close" }
          ) do %>
            Cancel
          <% end %>

          <% if @available_products.any? %>
            <%= render Ui::ButtonComponent.new(
              variant: :primary,
              type: "submit",
              form: "add-products-form",
              data: { product_selector_target: "submitButton" }
            ) do %>
              Add Selected Products
            <% end %>
          <% end %>
        <% end %>
      <% end %> <%# end form_with %>
    </div>
  <% end %>
<% end %>
