<%# Generic asset partial for Turbo Streams %>
<%# This partial delegates to the appropriate row partial based on asset type %>

<% case asset.product_asset_type %>
<% when 'document' %>
  <%= render "document_row", document: asset, product: product %>
<% when 'video' %>
  <%= render "video_row", video: asset, product: product %>
<% when 'link' %>
  <%= render "link_row", link: asset, product: product %>
<% end %>
