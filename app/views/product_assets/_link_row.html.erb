<li class="px-6 py-4 hover:bg-gray-50 transition-colors duration-150" data-sortable-id="<%= link.id %>">
  <div class="flex items-center gap-4">
    <!-- Drag Handle -->
    <div class="cursor-move text-gray-400 hover:text-gray-600" data-sortable-handle aria-label="Drag to reorder">
      <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M10 3a1.5 1.5 0 110 3 1.5 1.5 0 010-3zM10 8.5a1.5 1.5 0 110 3 1.5 1.5 0 010-3zM11.5 15.5a1.5 1.5 0 10-3 0 1.5 1.5 0 003 0z" />
      </svg>
    </div>

    <!-- Link Icon -->
    <div class="flex-shrink-0">
      <div class="h-12 w-12 rounded-lg bg-indigo-100 flex items-center justify-center">
        <svg class="h-6 w-6 text-indigo-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M12.232 4.232a2.5 2.5 0 013.536 3.536l-1.225 1.224a.75.75 0 001.061 1.06l1.224-1.224a4 4 0 00-5.656-5.656l-3 3a4 4 0 00.225 5.865.75.75 0 00.977-1.138 2.5 2.5 0 01-.142-3.667l3-3z" />
          <path d="M11.603 7.963a.75.75 0 00-.977 1.138 2.5 2.5 0 01.142 3.667l-3 3a2.5 2.5 0 01-3.536-3.536l1.225-1.224a.75.75 0 00-1.061-1.06l-1.224 1.224a4 4 0 105.656 5.656l3-3a4 4 0 00-.225-5.865z" />
        </svg>
      </div>
    </div>

    <!-- Link Info -->
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2">
        <h4 class="text-sm font-medium text-gray-900 truncate"><%= link.name %></h4>
        <%= render Ui::BadgeComponent.new(
          variant: case link.asset_visibility
                   when 'public_visibility' then :success
                   when 'catalog_only_visibility' then :info
                   else :gray
                   end,
          size: :sm
        ) do %>
          <%= link.asset_visibility&.humanize&.gsub(' visibility', '') || 'Private' %>
        <% end %>
      </div>
      <div class="flex items-center gap-4 mt-1 text-sm text-gray-500">
        <% if link.url.present? %>
          <span class="flex items-center gap-1 truncate">
            <svg class="h-4 w-4 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 00-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 00.75-.75v-4a.75.75 0 011.5 0v4A2.25 2.25 0 0112.75 17h-8.5A2.25 2.25 0 012 14.75v-8.5A2.25 2.25 0 014.25 4h5a.75.75 0 010 1.5h-5z" clip-rule="evenodd" />
              <path fill-rule="evenodd" d="M6.194 12.753a.75.75 0 001.06.053L16.5 4.44v2.81a.75.75 0 001.5 0v-4.5a.75.75 0 00-.75-.75h-4.5a.75.75 0 000 1.5h2.553l-9.056 8.194a.75.75 0 00-.053 1.06z" clip-rule="evenodd" />
            </svg>
            <span class="truncate"><%= link.url %></span>
          </span>
        <% end %>
        <span class="flex items-center gap-1 flex-shrink-0">
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-13a.75.75 0 00-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 000-1.5h-3.25V5z" clip-rule="evenodd" />
          </svg>
          <%= time_ago_in_words(link.created_at) %> ago
        </span>
      </div>
      <% if link.description.present? %>
        <p class="mt-1 text-sm text-gray-600 line-clamp-1"><%= link.description %></p>
      <% end %>
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-2 flex-shrink-0">
      <% if link.url.present? %>
        <%= render Ui::ButtonComponent.new(
          variant: :secondary,
          size: :sm,
          href: link.url,
          target: "_blank",
          rel: "noopener noreferrer",
          aria_label: "Open #{link.name} in new tab"
        ) do %>
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 00-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 00.75-.75v-4a.75.75 0 011.5 0v4A2.25 2.25 0 0112.75 17h-8.5A2.25 2.25 0 012 14.75v-8.5A2.25 2.25 0 014.25 4h5a.75.75 0 010 1.5h-5z" clip-rule="evenodd" />
            <path fill-rule="evenodd" d="M6.194 12.753a.75.75 0 001.06.053L16.5 4.44v2.81a.75.75 0 001.5 0v-4.5a.75.75 0 00-.75-.75h-4.5a.75.75 0 000 1.5h2.553l-9.056 8.194a.75.75 0 00-.053 1.06z" clip-rule="evenodd" />
          </svg>
          <span class="sr-only">Open in new tab</span>
        <% end %>
      <% end %>

      <%= render Ui::ButtonComponent.new(
        variant: :ghost,
        size: :sm,
        href: edit_product_product_asset_path(product, link),
        aria_label: "Edit #{link.name}"
      ) do %>
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M2.695 14.763l-1.262 3.154a.5.5 0 00.65.65l3.155-1.262a4 4 0 001.343-.885L17.5 5.5a2.121 2.121 0 00-3-3L3.58 13.42a4 4 0 00-.885 1.343z" />
        </svg>
        <span class="sr-only">Edit</span>
      <% end %>

      <%= render Ui::ButtonComponent.new(
        variant: :ghost,
        size: :sm,
        href: product_product_asset_path(product, link),
        data: {
          turbo_method: :delete,
          turbo_confirm: "Are you sure you want to delete #{link.name}?"
        },
        aria_label: "Delete #{link.name}"
      ) do %>
        <svg class="h-4 w-4 text-red-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 006 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 10.23 1.482l.149-.022.841 10.518A2.75 2.75 0 007.596 19h4.807a2.75 2.75 0 002.742-2.53l.841-10.52.149.023a.75.75 0 00.23-1.482A41.03 41.03 0 0014 4.193V3.75A2.75 2.75 0 0011.25 1h-2.5zM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4zM8.58 7.72a.75.75 0 00-1.5.06l.3 7.5a.75.75 0 101.5-.06l-.3-7.5zm4.34.06a.75.75 0 10-1.5-.06l-.3 7.5a.75.75 0 101.5.06l.3-7.5z" clip-rule="evenodd" />
        </svg>
        <span class="sr-only">Delete</span>
      <% end %>
    </div>
  </div>
</li>
