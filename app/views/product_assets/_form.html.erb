<%= form_with model: [product, product_asset],
              id: "asset_form",
              data: { controller: "asset-form asset-upload", turbo: true },
              html: { class: "space-y-6" } do |f| %>

  <!-- Asset Type Selector -->
  <div>
    <%= f.label :product_asset_type, "Asset Type", class: "block text-sm font-medium text-gray-700" %>
    <span class="text-red-600 ml-1" aria-hidden="true">*</span>
    <%= f.select :product_asset_type,
        options_for_select([
          ['Document (PDF, DOCX, etc.)', 'document'],
          ['Video (URL or file)', 'video'],
          ['External Link', 'link']
        ], product_asset.product_asset_type),
        {},
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
        required: true,
        data: {
          action: "change->asset-form#updateFields",
          asset_form_target: "typeSelect"
        } %>
  </div>

  <!-- Name Field (all types) -->
  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700" do %>
      Name
      <span class="text-red-600 ml-1" aria-hidden="true">*</span>
      <span class="sr-only">(required)</span>
    <% end %>
    <%= f.text_field :name,
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
        placeholder: "Asset name",
        required: true,
        aria: { required: "true" } %>
  </div>

  <!-- Description Field (all types) -->
  <div>
    <%= f.label :asset_description, "Description", class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :asset_description,
        rows: 3,
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
        placeholder: "Optional description" %>
  </div>

  <!-- Document File Upload (only for document type) -->
  <div data-asset-form-target="documentFields" class="<%= 'hidden' unless product_asset.product_asset_type == 'document' %>">
    <%= f.label :file, class: "block text-sm font-medium text-gray-700" do %>
      Document File
      <span class="text-red-600 ml-1" aria-hidden="true">*</span>
      <span class="sr-only">(required)</span>
    <% end %>
    <div class="mt-1">
      <div class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:border-gray-400 transition-colors"
           data-asset-upload-target="dropzone"
           data-action="drop->asset-upload#handleDrop dragover->asset-upload#handleDragOver dragleave->asset-upload#handleDragLeave">
        <svg class="mx-auto h-10 w-10 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
        </svg>
        <div class="mt-2">
          <label for="product_asset_file" class="cursor-pointer text-sm font-medium text-blue-600 hover:text-blue-500">
            Click to upload
          </label>
          <span class="text-sm text-gray-500"> or drag and drop</span>
        </div>
        <%= f.file_field :file,
            class: "sr-only",
            accept: ".pdf,.doc,.docx,.txt,.xls,.xlsx,.ppt,.pptx",
            data: { asset_form_target: "documentFile", asset_upload_target: "input", action: "change->asset-upload#handleFiles" } %>
        <p class="mt-1 text-xs text-gray-500">PDF, DOC, DOCX, TXT, XLS, XLSX, PPT, PPTX (max 10MB)</p>
      </div>
      <div data-asset-upload-target="progressContainer" class="mt-3"></div>
      <div data-asset-upload-target="errorContainer"></div>
    </div>
  </div>

  <!-- Video Fields (only for video type) -->
  <div data-asset-form-target="videoFields" class="<%= 'hidden' unless product_asset.product_asset_type == 'video' %>">
    <div class="space-y-4">
      <!-- Video URL -->
      <div data-controller="video-embed">
        <label for="product_asset_video_url" class="block text-sm font-medium text-gray-700">Video URL</label>
        <input type="url" name="product_asset[video_url]" id="product_asset_video_url"
            class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
            placeholder="https://www.youtube.com/watch?v=..."
            value="<%= product_asset.info&.dig('url') if product_asset.video? %>"
            data-asset-form-target="videoUrl"
            data-video-embed-target="urlInput"
            data-action="blur->video-embed#validateUrl input->video-embed#clearError">
        <p class="mt-1 text-xs text-gray-500">YouTube, Vimeo, or other video URL</p>
        <div data-video-embed-target="preview" class="hidden mt-3"></div>
        <div data-video-embed-target="errorMessage" class="hidden mt-2"></div>
        <input type="hidden" name="product_asset[video_id]" data-video-embed-target="videoIdInput">
        <input type="hidden" name="product_asset[video_platform]" data-video-embed-target="platformInput">
      </div>

      <!-- OR separator -->
      <div class="relative">
        <div class="absolute inset-0 flex items-center" aria-hidden="true">
          <div class="w-full border-t border-gray-300"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="bg-white px-2 text-gray-500">OR</span>
        </div>
      </div>

      <!-- Video File Upload -->
      <div>
        <%= f.label :file, "Upload Video File", class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <div class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:border-gray-400 transition-colors"
               data-asset-upload-target="dropzone"
               data-action="drop->asset-upload#handleDrop dragover->asset-upload#handleDragOver dragleave->asset-upload#handleDragLeave">
            <svg class="mx-auto h-10 w-10 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
            </svg>
            <div class="mt-2">
              <label for="product_asset_video_file" class="cursor-pointer text-sm font-medium text-blue-600 hover:text-blue-500">
                Click to upload
              </label>
              <span class="text-sm text-gray-500"> or drag and drop</span>
            </div>
            <%= f.file_field :file,
                id: "product_asset_video_file",
                class: "sr-only",
                accept: "video/*",
                data: { asset_form_target: "videoFile", asset_upload_target: "input", action: "change->asset-upload#handleFiles" } %>
            <p class="mt-1 text-xs text-gray-500">MP4, MOV, AVI, WEBM (max 100MB)</p>
          </div>
          <div data-asset-upload-target="progressContainer" class="mt-3"></div>
          <div data-asset-upload-target="errorContainer"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Link Fields (only for link type) -->
  <div data-asset-form-target="linkFields" class="<%= 'hidden' unless product_asset.product_asset_type == 'link' %>">
    <div class="space-y-4">
      <!-- Link URL -->
      <div>
        <label for="product_asset_link_url" class="block text-sm font-medium text-gray-700">
          URL
          <span class="text-red-600 ml-1" aria-hidden="true">*</span>
          <span class="sr-only">(required)</span>
        </label>
        <input type="url" name="product_asset[link_url]" id="product_asset_link_url"
            class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
            placeholder="https://example.com"
            value="<%= product_asset.info&.dig('url') if product_asset.link? %>"
            data-asset-form-target="linkUrl">
      </div>
    </div>
  </div>

  <!-- Visibility Selector -->
  <div>
    <%= f.label :asset_visibility, "Visibility", class: "block text-sm font-medium text-gray-700" %>
    <span class="text-red-600 ml-1" aria-hidden="true">*</span>
    <%= f.select :asset_visibility,
        options_for_select([
          ['Private (internal use only)', 'private_visibility'],
          ['Public (visible to everyone)', 'public_visibility'],
          ['Catalog Only (visible in catalogs)', 'catalog_only_visibility']
        ], product_asset.asset_visibility || 'private_visibility'),
        {},
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
        required: true %>
  </div>

  <!-- Position Field (hidden, for drag-drop reordering) -->
  <%= f.hidden_field :asset_priority, data: { asset_form_target: "position" } %>

  <!-- Form Errors -->
  <% if product_asset.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(product_asset.errors.count, "error") %> prevented this asset from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul role="list" class="list-disc space-y-1 pl-5">
              <% product_asset.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
