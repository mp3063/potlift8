<%# Product assets list partial - used by Turbo Stream responses %>
<% documents = assets.documents %>
<% videos = assets.videos %>
<% links = assets.links %>

<div id="product_assets">
  <!-- Documents Tab Content -->
  <div data-asset-manager-target="panel" data-tab-id="documents">
    <%= render Ui::CardComponent.new(padding: :none) do %>
      <% if documents.any? %>
        <div data-controller="asset-reorder"
             data-asset-reorder-reorder-url-value="<%= reorder_product_product_assets_path(product) %>"
             data-asset-reorder-handle-value=".drag-handle">
          <ul role="list" class="divide-y divide-gray-200" data-asset-reorder-target="container">
            <% documents.each do |document| %>
              <%= render "document_row", document: document, product: product %>
            <% end %>
          </ul>
        </div>
      <% else %>
        <div class="text-center py-12">
          <svg class="mx-auto h-12 w-12 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900">No documents</h3>
          <p class="mt-1 text-sm text-gray-500">Get started by uploading a document.</p>
        </div>
      <% end %>
    <% end %>
  </div>

  <!-- Videos Tab Content -->
  <div data-asset-manager-target="panel" data-tab-id="videos" class="hidden">
    <%= render Ui::CardComponent.new(padding: :none) do %>
      <% if videos.any? %>
        <div data-controller="asset-reorder"
             data-asset-reorder-reorder-url-value="<%= reorder_product_product_assets_path(product) %>"
             data-asset-reorder-handle-value=".drag-handle">
          <ul role="list" class="divide-y divide-gray-200" data-asset-reorder-target="container">
            <% videos.each do |video| %>
              <%= render "video_row", video: video, product: product %>
            <% end %>
          </ul>
        </div>
      <% else %>
        <div class="text-center py-12">
          <svg class="mx-auto h-12 w-12 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900">No videos</h3>
          <p class="mt-1 text-sm text-gray-500">Get started by uploading a video or adding a video URL.</p>
        </div>
      <% end %>
    <% end %>
  </div>

  <!-- Links Tab Content -->
  <div data-asset-manager-target="panel" data-tab-id="links" class="hidden">
    <%= render Ui::CardComponent.new(padding: :none) do %>
      <% if links.any? %>
        <div data-controller="asset-reorder"
             data-asset-reorder-reorder-url-value="<%= reorder_product_product_assets_path(product) %>"
             data-asset-reorder-handle-value=".drag-handle">
          <ul role="list" class="divide-y divide-gray-200" data-asset-reorder-target="container">
            <% links.each do |link| %>
              <%= render "link_row", link: link, product: product %>
            <% end %>
          </ul>
        </div>
      <% else %>
        <div class="text-center py-12">
          <svg class="mx-auto h-12 w-12 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900">No links</h3>
          <p class="mt-1 text-sm text-gray-500">Get started by adding an external link.</p>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
