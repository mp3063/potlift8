<%# Turbo Stream template for creating a new asset with errors
  Replaces the form with the updated form that includes error messages
  This template is rendered when form validation fails on create action
%>

<%= turbo_stream.replace "asset_form" do %>
  <%= render "form", product: @product, product_asset: @asset %>
<% end %>

<%= turbo_stream.update "flash" do %>
  <%= render "shared/flash", flash: flash %>
<% end %>
