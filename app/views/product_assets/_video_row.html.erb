<li class="px-6 py-4 hover:bg-gray-50 transition-colors duration-150" data-asset-id="<%= video.id %>">
  <div class="flex items-center gap-4">
    <!-- Bulk Selection Checkbox -->
    <input type="checkbox"
           value="<%= video.id %>"
           class="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
           data-asset-manager-target="checkbox"
           data-action="change->asset-manager#toggleSelection"
           aria-label="Select <%= video.name %>">

    <!-- Drag Handle -->
    <div class="drag-handle cursor-move text-gray-400 hover:text-gray-600" aria-label="Drag to reorder">
      <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M10 3a1.5 1.5 0 110 3 1.5 1.5 0 010-3zM10 8.5a1.5 1.5 0 110 3 1.5 1.5 0 010-3zM11.5 15.5a1.5 1.5 0 10-3 0 1.5 1.5 0 003 0z" />
      </svg>
    </div>

    <!-- Video Thumbnail/Icon -->
    <div class="flex-shrink-0">
      <% if video.thumbnail_url.present? %>
        <img src="<%= video.thumbnail_url %>" alt="<%= video.name %> thumbnail" class="h-16 w-24 rounded-lg object-cover">
      <% elsif video.url.present? && (video.url.include?('youtube.com') || video.url.include?('youtu.be')) %>
        <% video_id = video.url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&]+)/)&.captures&.first %>
        <% if video_id %>
          <img src="https://img.youtube.com/vi/<%= video_id %>/mqdefault.jpg" alt="<%= video.name %> thumbnail" class="h-16 w-24 rounded-lg object-cover">
        <% else %>
          <div class="h-16 w-24 rounded-lg bg-purple-100 flex items-center justify-center">
            <svg class="h-8 w-8 text-purple-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M3.25 4A2.25 2.25 0 001 6.25v7.5A2.25 2.25 0 003.25 16h7.5A2.25 2.25 0 0013 13.75v-7.5A2.25 2.25 0 0010.75 4h-7.5zM19 4.75a.75.75 0 00-1.28-.53l-3 3a.75.75 0 00-.22.53v4.5c0 .199.079.39.22.53l3 3a.75.75 0 001.28-.53V4.75z" />
            </svg>
          </div>
        <% end %>
      <% elsif video.url.present? && video.url.include?('vimeo.com') %>
        <div class="h-16 w-24 rounded-lg bg-blue-100 flex items-center justify-center">
          <svg class="h-8 w-8 text-blue-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M3.25 4A2.25 2.25 0 001 6.25v7.5A2.25 2.25 0 003.25 16h7.5A2.25 2.25 0 0013 13.75v-7.5A2.25 2.25 0 0010.75 4h-7.5zM19 4.75a.75.75 0 00-1.28-.53l-3 3a.75.75 0 00-.22.53v4.5c0 .199.079.39.22.53l3 3a.75.75 0 001.28-.53V4.75z" />
          </svg>
        </div>
      <% else %>
        <div class="h-16 w-24 rounded-lg bg-purple-100 flex items-center justify-center">
          <svg class="h-8 w-8 text-purple-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M3.25 4A2.25 2.25 0 001 6.25v7.5A2.25 2.25 0 003.25 16h7.5A2.25 2.25 0 0013 13.75v-7.5A2.25 2.25 0 0010.75 4h-7.5zM19 4.75a.75.75 0 00-1.28-.53l-3 3a.75.75 0 00-.22.53v4.5c0 .199.079.39.22.53l3 3a.75.75 0 001.28-.53V4.75z" />
          </svg>
        </div>
      <% end %>
    </div>

    <!-- Video Info -->
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2">
        <h4 class="text-sm font-medium text-gray-900 truncate"><%= video.name %></h4>
        <%= render Ui::BadgeComponent.new(
          variant: case video.asset_visibility
                   when 'public_visibility' then :success
                   when 'catalog_only_visibility' then :info
                   else :gray
                   end,
          size: :sm
        ) do %>
          <%= video.asset_visibility&.humanize&.gsub(' visibility', '') || 'Private' %>
        <% end %>
      </div>
      <div class="flex items-center gap-4 mt-1 text-sm text-gray-500">
        <% if video.url.present? %>
          <span class="flex items-center gap-1">
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M12.232 4.232a2.5 2.5 0 013.536 3.536l-1.225 1.224a.75.75 0 001.061 1.06l1.224-1.224a4 4 0 00-5.656-5.656l-3 3a4 4 0 00.225 5.865.75.75 0 00.977-1.138 2.5 2.5 0 01-.142-3.667l3-3z" />
              <path d="M11.603 7.963a.75.75 0 00-.977 1.138 2.5 2.5 0 01.142 3.667l-3 3a2.5 2.5 0 01-3.536-3.536l1.225-1.224a.75.75 0 00-1.061-1.06l-1.224 1.224a4 4 0 105.656 5.656l3-3a4 4 0 00-.225-5.865z" />
            </svg>
            <% if video.url.include?('youtube.com') || video.url.include?('youtu.be') %>
              YouTube
            <% elsif video.url.include?('vimeo.com') %>
              Vimeo
            <% else %>
              External URL
            <% end %>
          </span>
        <% elsif video.file_size.present? %>
          <span class="flex items-center gap-1">
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M15.621 4.379a3 3 0 00-4.242 0l-7 7a3 3 0 004.241 4.243h.001l.497-.5a.75.75 0 011.064 1.057l-.498.501-.002.002a4.5 4.5 0 01-6.364-6.364l7-7a4.5 4.5 0 016.368 6.36l-3.455 3.553A2.625 2.625 0 119.52 9.52l3.45-3.451a.75.75 0 111.061 1.06l-3.45 3.451a1.125 1.125 0 001.587 1.595l3.454-3.553a3 3 0 000-4.242z" clip-rule="evenodd" />
            </svg>
            <%= video.filename || 'Video file' %>
          </span>
          <span><%= number_to_human_size(video.file_size) %></span>
        <% end %>
        <span class="flex items-center gap-1">
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-13a.75.75 0 00-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 000-1.5h-3.25V5z" clip-rule="evenodd" />
          </svg>
          <%= time_ago_in_words(video.created_at) %> ago
        </span>
      </div>
      <% if video.description.present? %>
        <p class="mt-1 text-sm text-gray-600 line-clamp-1"><%= video.description %></p>
      <% end %>
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-2 flex-shrink-0">
      <% if video.url.present? %>
        <%= render Ui::ButtonComponent.new(
          variant: :secondary,
          size: :sm,
          href: video.url,
          target: "_blank",
          aria_label: "Watch #{video.name}"
        ) do %>
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z" />
          </svg>
          <span class="sr-only">Watch</span>
        <% end %>
      <% elsif video.file_url.present? %>
        <%= render Ui::ButtonComponent.new(
          variant: :secondary,
          size: :sm,
          href: video.file_url,
          target: "_blank",
          aria_label: "Play #{video.name}"
        ) do %>
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z" />
          </svg>
          <span class="sr-only">Play</span>
        <% end %>
      <% end %>

      <%= render Ui::ButtonComponent.new(
        variant: :ghost,
        size: :sm,
        href: edit_product_product_asset_path(product, video),
        aria_label: "Edit #{video.name}"
      ) do %>
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M2.695 14.763l-1.262 3.154a.5.5 0 00.65.65l3.155-1.262a4 4 0 001.343-.885L17.5 5.5a2.121 2.121 0 00-3-3L3.58 13.42a4 4 0 00-.885 1.343z" />
        </svg>
        <span class="sr-only">Edit</span>
      <% end %>

      <%= render Ui::ButtonComponent.new(
        variant: :ghost,
        size: :sm,
        href: product_product_asset_path(product, video),
        data: {
          turbo_method: :delete,
          turbo_confirm: "Are you sure you want to delete #{video.name}?"
        },
        aria_label: "Delete #{video.name}"
      ) do %>
        <svg class="h-4 w-4 text-red-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 006 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 10.23 1.482l.149-.022.841 10.518A2.75 2.75 0 007.596 19h4.807a2.75 2.75 0 002.742-2.53l.841-10.52.149.023a.75.75 0 00.23-1.482A41.03 41.03 0 0014 4.193V3.75A2.75 2.75 0 0011.25 1h-2.5zM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4zM8.58 7.72a.75.75 0 00-1.5.06l.3 7.5a.75.75 0 101.5-.06l-.3-7.5zm4.34.06a.75.75 0 10-1.5-.06l-.3 7.5a.75.75 0 101.5.06l.3-7.5z" clip-rule="evenodd" />
        </svg>
        <span class="sr-only">Delete</span>
      <% end %>
    </div>
  </div>
</li>
