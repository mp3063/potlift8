<% content_for :page_header do %>
  <div class="flex items-center justify-between">
    <div>
      <div class="flex items-center gap-3">
        <%= link_to product_versions_path(@product), class: "text-gray-500 hover:text-gray-700" do %>
          <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          <span class="sr-only">Back to version history</span>
        <% end %>
        <h1 class="text-2xl font-bold text-gray-900">Version Details</h1>
      </div>
      <p class="mt-2 text-sm text-gray-700">
        <%= @product.name %> - <%= @version.created_at.strftime("%B %d, %Y at %I:%M %p") %>
      </p>
    </div>

    <div class="flex items-center gap-3">
      <%= link_to compare_product_versions_path(@product, from: @version.id) do %>
        <%= render Ui::ButtonComponent.new(variant: :secondary) do %>
          <svg class="h-5 w-5 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
          </svg>
          Compare Versions
        <% end %>
      <% end %>

      <% unless @is_current_version %>
        <%= button_to revert_product_version_path(@product, @version), method: :post, form: { data: { turbo_confirm: "Are you sure you want to revert to this version?" } } do %>
          <%= render Ui::ButtonComponent.new(variant: :primary) do %>
            <svg class="h-5 w-5 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6" />
            </svg>
            Revert to This Version
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<!-- Version Metadata -->
<%= render Ui::CardComponent.new do |card| %>
  <% card.with_header do %>
    <h3 class="text-lg font-semibold text-gray-900">Version Information</h3>
  <% end %>

  <dl class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <dt class="text-sm font-medium text-gray-500">Timestamp</dt>
      <dd class="mt-1 text-sm text-gray-900">
        <time datetime="<%= @version.created_at.iso8601 %>">
          <%= @version.created_at.strftime("%B %d, %Y at %I:%M %p") %>
        </time>
      </dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-gray-500">Changed By</dt>
      <dd class="mt-1 text-sm text-gray-900">
        <%= @version.whodunnit || "System" %>
      </dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-gray-500">Event Type</dt>
      <dd class="mt-1">
        <% event_badge = case @version.event
          when "create" then { variant: :success, text: "Created" }
          when "update" then { variant: :info, text: "Updated" }
          when "destroy" then { variant: :danger, text: "Deleted" }
          else { variant: :gray, text: @version.event&.titleize || "Unknown" }
        end %>
        <%= render Ui::BadgeComponent.new(variant: event_badge[:variant]) do %>
          <%= event_badge[:text] %>
        <% end %>
      </dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-gray-500">Version Number</dt>
      <dd class="mt-1 text-sm text-gray-900">
        #<%= @version.id %>
      </dd>
    </div>
  </dl>
<% end %>

<!-- Changed Attributes -->
<div class="mt-8">
  <h2 class="text-lg font-semibold text-gray-900 mb-4">Changed Attributes</h2>

  <% if @changes.any? %>
    <div class="space-y-4">
      <% @changes.each do |attribute_name, (old_value, new_value)| %>
        <%= render DiffViewComponent.new(
          old_value: old_value,
          new_value: new_value,
          attribute_name: attribute_name
        ) %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12 bg-gray-50 rounded-lg border border-gray-200">
      <svg class="mx-auto h-12 w-12 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <p class="mt-2 text-sm text-gray-600">No attribute changes recorded for this version</p>
    </div>
  <% end %>
</div>
