<% content_for :page_header do %>
  <nav class="flex mb-4" aria-label="Breadcrumb">
    <ol role="list" class="flex items-center space-x-4">
      <li>
        <%= link_to products_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700" do %>
          Products
        <% end %>
      </li>
      <li class="flex items-center">
        <svg class="h-5 w-5 flex-shrink-0 text-gray-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M5.555 17.776l8-16 .894.448-8 16-.894-.448z" />
        </svg>
        <%= link_to product_path(@product), class: "ml-4 text-sm font-medium text-gray-500 hover:text-gray-700" do %>
          <%= @product.name %>
        <% end %>
      </li>
      <li class="flex items-center">
        <svg class="h-5 w-5 flex-shrink-0 text-gray-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M5.555 17.776l8-16 .894.448-8 16-.894-.448z" />
        </svg>
        <span class="ml-4 text-sm font-medium text-gray-700" aria-current="page">Variants</span>
      </li>
    </ol>
  </nav>

  <div class="md:flex md:items-center md:justify-between">
    <div class="min-w-0 flex-1">
      <h1 class="text-2xl font-bold text-gray-900">Product Variants</h1>
      <p class="mt-2 text-sm text-gray-700">
        <%= @product.name %> has <%= pluralize(@variants.count, 'variant') %>
      </p>
    </div>
    <div class="mt-4 flex flex-wrap md:ml-4 md:mt-0 gap-3">
      <%= link_to product_configurations_path(@product), class: "inline-flex items-center justify-center font-medium rounded-lg transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 px-4 py-2 text-sm bg-white hover:bg-gray-50 focus:ring-blue-500 text-gray-700 border border-gray-300" do %>
        <svg class="-ml-0.5 mr-1.5 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
        </svg>
        Manage Configurations
      <% end %>

      <% if @configurations.any? %>
        <%= button_to generate_product_variants_path(@product), method: :post, form: { data: { turbo_confirm: "Generate all possible variant combinations? This may create many products." } }, class: "inline-flex items-center justify-center font-medium rounded-lg transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 px-4 py-2 text-sm bg-white hover:bg-gray-50 focus:ring-blue-500 text-gray-700 border border-gray-300" do %>
          <svg class="-ml-0.5 mr-1.5 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
          </svg>
          Generate All Variants
        <% end %>
      <% end %>

      <%= link_to new_product_variant_path(@product), class: "inline-flex items-center justify-center font-medium rounded-lg transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 px-4 py-2 text-sm bg-blue-600 hover:bg-blue-700 focus:ring-blue-500 text-white" do %>
        <svg class="-ml-0.5 mr-1.5 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        New Variant
      <% end %>
    </div>
  </div>
<% end %>

<!-- Configuration Dimensions Display -->
<% if @configurations.any? %>
  <div class="mb-6 rounded-lg border border-blue-200 bg-blue-50 p-4">
    <div class="flex">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-blue-600" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="ml-3 flex-1">
        <h3 class="text-sm font-medium text-blue-800">Configuration Dimensions</h3>
        <div class="mt-2 text-sm text-blue-700">
          <ul class="list-disc space-y-1 pl-5">
            <% @configurations.each do |config| %>
              <li>
                <strong><%= config.name %>:</strong>
                <%= config.configuration_values.pluck(:value).join(', ') %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  </div>
<% end %>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden" data-controller="variant-list">
  <% if @variants.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-300">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6">
              <span class="sr-only">Drag Handle</span>
            </th>
            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">
              SKU
            </th>
            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">
              Variant Name
            </th>
            <% @configurations.each do |config| %>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">
                <%= config.name %>
              </th>
            <% end %>
            <th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-gray-900">
              Inventory
            </th>
            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">
              Status
            </th>
            <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
              <span class="sr-only">Actions</span>
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white" data-variant-list-target="tbody">
          <% @variants.each do |variant| %>
            <tr class="hover:bg-gray-50 group" data-variant-id="<%= variant.id %>">
              <td class="whitespace-nowrap py-4 pl-4 pr-3 sm:pl-6">
                <div class="cursor-move text-gray-400 hover:text-gray-600">
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16" />
                  </svg>
                </div>
              </td>
              <td class="whitespace-nowrap px-3 py-4 text-sm font-medium text-gray-900">
                <%= link_to variant.variant_product.sku, product_path(variant.variant_product), class: "text-blue-600 hover:text-blue-900 hover:underline" %>
              </td>
              <td class="px-3 py-4 text-sm text-gray-900">
                <%= variant.variant_product.name %>
              </td>
              <% @configurations.each do |config| %>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                  <% config_value = variant.variant_configuration_values.find_by(configuration: config)&.configuration_value %>
                  <%= config_value&.value || '—' %>
                </td>
              <% end %>
              <td class="whitespace-nowrap px-3 py-4 text-sm text-right text-gray-900 font-medium">
                <%= variant.variant_product.total_inventory %>
              </td>
              <td class="whitespace-nowrap px-3 py-4 text-sm">
                <% if variant.variant_product.active? %>
                  <%= render Ui::BadgeComponent.new(variant: :success, dot: true) { "Active" } %>
                <% else %>
                  <%= render Ui::BadgeComponent.new(variant: :gray) { "Inactive" } %>
                <% end %>
              </td>
              <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                <div class="flex justify-end gap-x-3">
                  <%= link_to "Edit", edit_product_variant_path(@product, variant), class: "text-blue-600 hover:text-blue-900 hover:underline" %>
                  <%= button_to "Delete", product_variant_path(@product, variant), method: :delete, form: { data: { turbo_confirm: "Delete this variant?" } }, class: "text-red-600 hover:text-red-900 hover:underline" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <%= render Shared::EmptyStateComponent.new(
      title: "No variants",
      description: @configurations.empty? ? "First create configuration dimensions, then add variants." : "Get started by creating a variant or generating all combinations.",
      icon: :package
    ) do %>
      <% if @configurations.empty? %>
        <%= link_to product_configurations_path(@product), class: "inline-flex items-center justify-center font-medium rounded-lg transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 px-4 py-2 text-sm bg-blue-600 hover:bg-blue-700 focus:ring-blue-500 text-white" do %>
          <svg class="-ml-0.5 mr-1.5 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Create Configuration
        <% end %>
      <% else %>
        <%= link_to new_product_variant_path(@product), class: "inline-flex items-center justify-center font-medium rounded-lg transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 px-4 py-2 text-sm bg-blue-600 hover:bg-blue-700 focus:ring-blue-500 text-white" do %>
          <svg class="-ml-0.5 mr-1.5 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          New Variant
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>
