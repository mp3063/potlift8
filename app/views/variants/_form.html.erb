<%= form_with(url: variant_product.persisted? ? product_variant_path(@product, @variant) : product_variants_path(@product), method: variant_product.persisted? ? :patch : :post, local: true) do |form| %>
  <% if variant_product.errors.any? %>
    <%= render Shared::FormErrorsComponent.new(errors: variant_product.errors) %>
  <% end %>

  <%= render Ui::CardComponent.new do |card| %>
    <% card.with_header do %>
      <h3 class="text-lg font-semibold text-gray-900">Variant Product Details</h3>
    <% end %>

    <div class="space-y-6">
      <!-- SKU Field -->
      <div>
        <%= form.label :sku, "SKU", for: "variant_product_sku", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <p class="text-xs text-gray-500 mb-2">
          Unique product identifier. Leave blank to auto-generate.
        </p>
        <%= form.text_field :sku,
          name: "variant_product[sku]",
          id: "variant_product_sku",
          value: variant_product.sku,
          class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
          placeholder: "e.g., TSH-BLU-M" %>
      </div>

      <!-- Name Field -->
      <div>
        <%= form.label :name, "Variant Name", for: "variant_product_name", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <p class="text-xs text-gray-500 mb-2">
          Leave blank to auto-generate from configuration values
        </p>
        <%= form.text_field :name,
          name: "variant_product[name]",
          id: "variant_product_name",
          value: variant_product.name,
          class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
          placeholder: "Auto-generated if blank" %>
      </div>

      <!-- Description Field -->
      <div>
        <%= form.label :description, "Description", for: "variant_product_description", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_area :description,
          name: "variant_product[description]",
          id: "variant_product_description",
          value: variant_product.description,
          rows: 4,
          class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
          placeholder: "Optional variant-specific description" %>
      </div>
    </div>
  <% end %>

  <!-- Configuration Values Section -->
  <% if @configurations.present? %>
    <%= render Ui::CardComponent.new(class: "mt-6") do |card| %>
      <% card.with_header do %>
        <h3 class="text-lg font-semibold text-gray-900">Configuration Values</h3>
        <p class="text-sm text-gray-600 mt-1">
          Select the configuration values that define this variant
        </p>
      <% end %>

      <div class="space-y-6">
        <% @configurations.each do |configuration| %>
          <% current_value = variant_config&.dig(configuration.code) %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2"><%= configuration.name %></label>

            <% if configuration.configuration_values.any? %>
              <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
                <% configuration.configuration_values.order(:position).each do |config_value| %>
                  <% is_selected = current_value == config_value.value %>
                  <label class="relative flex cursor-pointer rounded-lg border bg-white p-4 hover:border-blue-500 focus-within:ring-2 focus-within:ring-blue-500 focus-within:ring-offset-2 <%= is_selected ? 'border-blue-600 bg-blue-50' : 'border-gray-300' %>">
                    <input type="radio"
                           name="variant_config[<%= configuration.code %>]"
                           value="<%= config_value.id %>"
                           class="sr-only"
                           <%= 'checked' if is_selected %>>

                    <span class="flex flex-1">
                      <span class="flex flex-col">
                        <span class="block text-sm font-medium <%= is_selected ? 'text-blue-600' : 'text-gray-900' %>">
                          <%= config_value.value %>
                        </span>
                      </span>
                    </span>

                    <!-- Selected Checkmark -->
                    <svg class="h-5 w-5 text-blue-600 <%= is_selected ? '' : 'hidden' %>" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                    </svg>
                  </label>
                <% end %>
              </div>
            <% else %>
              <p class="text-sm text-gray-500 italic">No values defined for this configuration. <%= link_to "Add values", edit_product_configuration_path(@product, configuration), class: "text-blue-600 hover:text-blue-500" %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <%= render Ui::CardComponent.new(class: "mt-6") do |card| %>
      <% card.with_header do %>
        <h3 class="text-lg font-semibold text-gray-900">Configuration Values</h3>
      <% end %>

      <div class="text-center py-8">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No configurations defined</h3>
        <p class="mt-1 text-sm text-gray-500">
          Add configuration dimensions first (e.g., Size, Color) before creating variants.
        </p>
        <div class="mt-4">
          <%= link_to "Add Configuration", new_product_configuration_path(@product), class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
        </div>
      </div>
    <% end %>
  <% end %>

  <!-- Form Actions -->
  <div class="mt-6 flex items-center justify-end gap-3">
    <%= link_to "Cancel", product_variants_path(@product), class: "inline-flex items-center justify-center font-medium rounded-lg transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 px-4 py-2 text-sm bg-white hover:bg-gray-50 focus:ring-blue-500 text-gray-700 border border-gray-300" %>

    <%= render Ui::ButtonComponent.new(variant: :primary, type: "submit") do %>
      <%= variant_product.persisted? ? 'Update Variant' : 'Create Variant' %>
    <% end %>
  </div>
<% end %>

<script>
  // Handle radio button selection UI updates
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('input[type="radio"][name^="variant_config"]').forEach(function(radio) {
      radio.addEventListener('change', function() {
        // Find all labels in this configuration group
        const name = this.name;
        document.querySelectorAll(`input[type="radio"][name="${name}"]`).forEach(function(r) {
          const label = r.closest('label');
          const checkmark = label.querySelector('svg');
          const text = label.querySelector('span span span');

          if (r.checked) {
            label.classList.remove('border-gray-300');
            label.classList.add('border-blue-600', 'bg-blue-50');
            checkmark.classList.remove('hidden');
            text.classList.remove('text-gray-900');
            text.classList.add('text-blue-600');
          } else {
            label.classList.add('border-gray-300');
            label.classList.remove('border-blue-600', 'bg-blue-50');
            checkmark.classList.add('hidden');
            text.classList.add('text-gray-900');
            text.classList.remove('text-blue-600');
          }
        });
      });
    });
  });
</script>
