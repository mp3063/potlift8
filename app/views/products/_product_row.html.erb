<%# Product Row Partial with Fragment Caching
#
# This partial is optimized for fragment caching using the Russian Doll pattern.
# Each product row is cached individually, with nested caches for labels.
#
# Cache Key Components:
# - product: Product object (includes id and updated_at via cache_key_with_version)
# - product.labels.maximum(:updated_at): Last update to any label on this product
# - company_id: For multi-tenancy isolation
#
# Cache Invalidation:
# - Automatic when product is updated (updated_at changes)
# - Automatic when product labels are added/removed (labels.updated_at changes)
# - Manual: Rails.cache.delete(['product-row', product, ...])
#
# Performance Impact:
# - First render: ~50ms (database queries for product + labels)
# - Cached render: ~1ms (reads from cache)
# - Cache hit rate: Expected 90%+ for stable product lists
#
# Usage:
#   <%= render partial: 'products/product_row', collection: @products, as: :product %>
#   <%= render 'products/product_row', product: @product %>
#
%>
<% cache ['product-row-v1', product, product.labels.maximum(:updated_at), current_potlift_company.id] do %>
  <tr class="hover:bg-gray-50 transition-colors" data-product-id="<%= product.id %>">
    <td class="px-6 py-4 whitespace-nowrap">
      <input
        type="checkbox"
        class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-600"
        data-bulk-actions-target="checkbox"
        data-action="change->bulk-actions#toggleCheckbox"
        value="<%= product.id %>"
        aria-label="Select <%= product.name %>"
      >
    </td>
    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
      <%= link_to product.sku, product_path(product), class: "text-blue-600 hover:text-blue-900", data: { turbo_frame: "_top" } %>
    </td>
    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
      <%= product.name %>
    </td>
    <td class="px-6 py-4 whitespace-nowrap">
      <%= product_type_badge(product) %>
    </td>
    <td class="px-6 py-4 text-sm text-gray-700">
      <%# Nested cache for labels - invalidates when labels change %>
      <% cache ['product-labels-v1', product.id, product.labels.maximum(:updated_at)] do %>
        <div class="flex flex-wrap gap-1">
          <% labels_to_show = product.labels.take(3) %>
          <% total_labels = product.labels.size %>
          <% labels_to_show.each do |label| %>
            <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-800">
              <%= label.name %>
            </span>
          <% end %>
          <% if total_labels > 3 %>
            <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-800">
              +<%= total_labels - 3 %>
            </span>
          <% end %>
        </div>
      <% end %>
    </td>
    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
      <%= product.total_inventory %>
    </td>
    <td class="px-6 py-4 whitespace-nowrap">
      <%= product_status_badge(product) %>
    </td>
    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
      <%= product.created_at.strftime('%Y-%m-%d') %>
    </td>
    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
      <div class="flex justify-end gap-2">
        <%= link_to edit_product_path(product), class: "text-blue-600 hover:text-blue-900 inline-flex items-center", title: "Edit #{product.name}", data: { turbo_frame: "_top" } do %>
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M2.695 14.763l-1.262 3.154a.5.5 0 00.65.65l3.155-1.262a4 4 0 001.343-.885L17.5 5.5a2.121 2.121 0 00-3-3L3.58 13.42a4 4 0 00-.885 1.343z" />
          </svg>
          <span class="sr-only">Edit</span>
        <% end %>

        <%= link_to duplicate_product_path(product), data: { turbo_method: :post }, class: "text-gray-600 hover:text-gray-900 inline-flex items-center", title: "Duplicate #{product.name}" do %>
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M7 3.5A1.5 1.5 0 018.5 2h3.879a1.5 1.5 0 011.06.44l3.122 3.12A1.5 1.5 0 0117 6.622V12.5a1.5 1.5 0 01-1.5 1.5h-1v-3.379a3 3 0 00-.879-2.121L10.5 5.379A3 3 0 008.379 4.5H7v-1z" />
            <path d="M4.5 6A1.5 1.5 0 003 7.5v9A1.5 1.5 0 004.5 18h7a1.5 1.5 0 001.5-1.5v-5.879a1.5 1.5 0 00-.44-1.06L9.44 6.439A1.5 1.5 0 008.378 6H4.5z" />
          </svg>
          <span class="sr-only">Duplicate</span>
        <% end %>

        <%= button_to product_path(product),
            method: :delete,
            form: { data: { turbo_confirm: "Are you sure you want to delete #{product.name}?" } },
            class: "text-red-600 hover:text-red-900 inline-flex items-center",
            title: "Delete #{product.name}" do %>
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 006 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 10.23 1.482l.149-.022.841 10.518A2.75 2.75 0 007.596 19h4.807a2.75 2.75 0 002.742-2.53l.841-10.52.149.023a.75.75 0 00.23-1.482A41.03 41.03 0 0014 4.193V3.75A2.75 2.75 0 0011.25 1h-2.5zM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4zM8.58 7.72a.75.75 0 00-1.5.06l.3 7.5a.75.75 0 101.5-.06l-.3-7.5zm4.34.06a.75.75 0 10-1.5-.06l-.3 7.5a.75.75 0 101.5.06l.3-7.5z" clip-rule="evenodd" />
          </svg>
          <span class="sr-only">Delete</span>
        <% end %>
      </div>
    </td>
  </tr>
<% end %>
