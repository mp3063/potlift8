<div class="px-4 sm:px-6 lg:px-8" data-controller="bulk-actions">
  <!-- Page Header -->
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-3xl font-semibold leading-6 text-gray-900">Products</h1>
      <p class="mt-2 text-sm text-gray-700">
        Manage your inventory products, including sellable items, configurable products, and bundles.
      </p>
    </div>
    <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none">
      <%= link_to new_product_path, class: "block rounded-md bg-blue-600 px-3 py-2 text-center text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600" do %>
        <svg class="-ml-0.5 mr-1.5 h-5 w-5 inline-block" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z" />
        </svg>
        Add Product
      <% end %>
    </div>
  </div>

  <!-- Search and Filters -->
  <div class="mt-8">
    <%= form_with url: products_path, method: :get, data: { turbo_frame: 'products_table' }, class: "space-y-4" do |f| %>
      <!-- Main search and type filter row -->
      <div class="sm:flex sm:gap-x-4">
        <div class="flex-1">
          <label for="search" class="sr-only">Search</label>
          <div class="relative">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
              <svg class="h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
              </svg>
            </div>
            <%= f.text_field :q,
                value: params[:q],
                placeholder: "Search products by name or SKU...",
                class: "block w-full rounded-md border-0 py-1.5 pl-10 text-gray-900 ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6",
                aria: { label: "Search products" } %>
          </div>
        </div>

        <div class="mt-4 sm:mt-0">
          <%= f.select :product_type,
              options_for_select([
                ['All Types', ''],
                ['Sellable', 1],
                ['Configurable', 2],
                ['Bundle', 3]
              ], params[:product_type]),
              {},
              class: "block w-full rounded-md border-0 py-1.5 pl-3 pr-10 text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-blue-600 sm:text-sm sm:leading-6",
              aria: { label: "Filter by product type" },
              data: { action: "change->submit#submit" } %>
        </div>

        <!-- Label filter dropdown -->
        <div class="mt-4 sm:mt-0 relative" data-controller="dropdown">
          <button
            type="button"
            data-action="click->dropdown#toggle"
            data-dropdown-target="button"
            aria-expanded="false"
            aria-haspopup="true"
            class="inline-flex w-full justify-between gap-x-1.5 rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50">
            <span>Filter by Label</span>
            <svg class="h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
            </svg>
          </button>

          <div
            data-dropdown-target="menu"
            class="hidden absolute right-0 z-10 mt-2 w-72 origin-top-right rounded-md bg-white shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none max-h-96 overflow-y-auto"
            role="menu"
            aria-orientation="vertical">
            <div class="py-1">
              <% if @available_labels.any? %>
                <% @available_labels.each do |label| %>
                  <%= link_to products_path(label_id: label.id, q: params[:q], product_type: params[:product_type]),
                      class: "flex items-center justify-between px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 hover:text-gray-900",
                      role: "menuitem" do %>
                    <span class="font-medium"><%= label.name %></span>
                    <span class="text-gray-500">(<%= @label_product_counts[label.id] || 0 %>)</span>
                  <% end %>

                  <% if label.sublabels.any? %>
                    <% label.sublabels.each do |sublabel| %>
                      <%= link_to products_path(label_id: sublabel.id, q: params[:q], product_type: params[:product_type]),
                          class: "flex items-center justify-between px-4 py-2 pl-8 text-sm text-gray-600 hover:bg-gray-100 hover:text-gray-900",
                          role: "menuitem" do %>
                        <span><%= sublabel.name %></span>
                        <span class="text-gray-400">(<%= @label_product_counts[sublabel.id] || 0 %>)</span>
                      <% end %>
                    <% end %>
                  <% end %>
                <% end %>
              <% else %>
                <div class="px-4 py-2 text-sm text-gray-500">No labels available</div>
              <% end %>
            </div>
          </div>
        </div>

        <div class="mt-4 sm:mt-0 flex gap-x-2">
          <%= f.submit "Search", class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
          <% if params[:q].present? || params[:product_type].present? || params[:label_id].present? %>
            <%= link_to "Clear", products_path, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
          <% end %>
        </div>
      </div>

      <!-- Active filters display -->
      <% if @current_label.present? %>
        <div class="flex flex-wrap gap-2 items-center">
          <span class="text-sm text-gray-700">Active filters:</span>
          <span class="inline-flex items-center gap-x-1.5 rounded-full bg-blue-100 px-3 py-1 text-sm font-medium text-blue-800">
            <svg class="h-2 w-2 fill-blue-500" viewBox="0 0 6 6" aria-hidden="true">
              <circle cx="3" cy="3" r="3" />
            </svg>
            <%= @current_label.full_name %>
            <%= link_to products_path(q: params[:q], product_type: params[:product_type]),
                class: "ml-1 inline-flex h-5 w-5 items-center justify-center rounded-full hover:bg-blue-200 focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2 focus:ring-offset-blue-100",
                aria: { label: "Remove label filter" } do %>
              <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
              </svg>
            <% end %>
          </span>
        </div>
      <% end %>
    <% end %>
  </div>

  <!-- Bulk Actions Toolbar (hidden by default) -->
  <div class="mt-4 hidden" data-bulk-actions-target="toolbar">
    <div class="rounded-md bg-blue-50 p-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z" clip-rule="evenodd" />
          </svg>
          <p class="ml-3 text-sm font-medium text-blue-800">
            <span data-bulk-actions-target="count">0</span> product(s) selected
          </p>
        </div>
        <div class="flex gap-x-2">
          <button
            type="button"
            data-action="click->bulk-actions#bulkExport"
            class="rounded-md bg-white px-2.5 py-1.5 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50">
            Export CSV
          </button>
          <button
            type="button"
            data-action="click->bulk-actions#bulkDelete"
            class="rounded-md bg-red-600 px-2.5 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-red-500">
            Delete Selected
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Products Table -->
  <%= render Products::TableComponent.new(
    products: @products,
    pagy: @pagy,
    current_sort: params[:sort],
    current_direction: params[:direction]
  ) %>
</div>
