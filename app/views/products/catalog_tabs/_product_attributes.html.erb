<div class="space-y-4">
  <% all_attributes.each do |product_attribute| %>
    <% attribute_value = attribute_values[product_attribute] %>
    <% has_value = attribute_value.present? && attribute_value.value.present? %>

    <div class="py-3 border-b border-gray-200">
      <%= turbo_frame_tag dom_id(product_attribute, :value) do %>
        <div class="group" data-controller="inline-editor" data-inline-editor-url-value="<%= product_attribute_value_path(product, product_attribute) %>">
          <!-- Display Mode -->
          <div class="flex items-start justify-between" data-inline-editor-target="display">
            <div class="flex-1">
              <dt class="text-base font-semibold text-gray-700"><%= product_attribute.name %></dt>
              <dd class="mt-1 text-sm <%= has_value ? 'text-gray-900' : 'text-gray-400 italic' %>">
                <%= has_value ? attribute_value.value : 'Not set' %>
              </dd>
              <% if product_attribute.description.present? %>
                <dd class="mt-1 text-xs text-gray-500"><%= product_attribute.description %></dd>
              <% end %>
            </div>
            <div class="ml-4">
              <%= button_tag type: "button",
                  class: "p-1 opacity-0 group-hover:opacity-100 transition-opacity text-gray-400 hover:text-gray-600 rounded hover:bg-gray-100",
                  data: { action: "click->inline-editor#edit" },
                  aria: { label: "Edit #{product_attribute.name}" } do %>
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
              <% end %>
            </div>
          </div>

          <!-- Edit Mode -->
          <div class="hidden" data-inline-editor-target="editor">
            <%= form_with url: product_attribute_value_path(product, product_attribute),
                method: :patch,
                data: {
                  inline_editor_target: "form",
                  action: "turbo:submit-end->inline-editor#handleSubmit"
                } do |form| %>
              <div class="space-y-3">
                <div>
                  <label class="block text-sm font-medium text-gray-700"><%= product_attribute.name %></label>
                  <% if product_attribute.patype_select? %>
                    <%= form.select :value,
                        options_for_select(product_attribute.options, attribute_value&.value),
                        { prompt: "Select an option" },
                        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
                  <% elsif product_attribute.patype_multiselect? %>
                    <%= form.select :value,
                        options_for_select(product_attribute.options, attribute_value&.value),
                        { prompt: "Select options" },
                        multiple: true,
                        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
                  <% elsif product_attribute.patype_boolean? %>
                    <%= form.check_box :value,
                        { checked: attribute_value&.value == 'true' },
                        class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
                  <% elsif product_attribute.patype_number? %>
                    <%= form.number_field :value,
                        value: attribute_value&.value,
                        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
                        placeholder: "Enter #{product_attribute.name.downcase}" %>
                  <% elsif product_attribute.patype_date? %>
                    <%= form.date_field :value,
                        value: attribute_value&.value,
                        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
                  <% elsif product_attribute.patype_rich_text? %>
                    <%= form.text_area :value,
                        value: attribute_value&.value,
                        rows: 4,
                        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
                        placeholder: "Enter #{product_attribute.name.downcase}" %>
                  <% else %>
                    <%= form.text_field :value,
                        value: attribute_value&.value,
                        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
                        placeholder: "Enter #{product_attribute.name.downcase}" %>
                  <% end %>
                  <% if product_attribute.description.present? %>
                    <p class="mt-1 text-xs text-gray-500"><%= product_attribute.description %></p>
                  <% end %>
                </div>

                <div class="flex gap-x-2">
                  <%= render Ui::ButtonComponent.new(variant: :primary, type: "submit", size: :sm) do %>
                    Save
                  <% end %>
                  <%= render Ui::ButtonComponent.new(
                    variant: :secondary,
                    type: "button",
                    size: :sm,
                    data: { action: "click->inline-editor#cancel" }
                  ) do %>
                    Cancel
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if all_attributes.empty? %>
    <div class="text-center py-12">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No attributes defined</h3>
      <p class="mt-1 text-sm text-gray-500">This company has no product attributes defined yet.</p>
    </div>
  <% end %>
</div>
