<%# Turbo Stream response for removing product from catalog %>
<%# Replaces only the catalog tabs section with updated data %>

<turbo-stream action="replace" target="catalog-tabs-<%= @product.id %>">
  <template>
    <% self.formats = [:html] %>
    <%= turbo_frame_tag "catalog-tabs-#{@product.id}" do %>
      <%= render Products::CatalogTabsComponent.new(
        product: @product,
        catalog_items: @product.catalog_items.reload,
        attribute_values: @product.product_attribute_values.each_with_object({}) { |pav, hash| hash[pav.product_attribute] = pav },
        available_catalogs: @product.company.catalogs.where.not(id: @product.catalog_items.map(&:catalog_id)).order(:name)
      ) %>
    <% end %>
  </template>
</turbo-stream>

