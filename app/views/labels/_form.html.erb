<%
  # Form partial for creating/editing labels
  # Locals: label (required), parent_label (optional)
  parent_label ||= nil
  is_new = label.new_record?
  form_title = is_new ? "New Label" : "Edit Label"
  submit_text = is_new ? "Create Label" : "Update Label"
%>

<!-- Modal Overlay -->
<div class="fixed inset-0 z-50 overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true" data-controller="modal">
  <!-- Backdrop -->
  <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" data-action="click->modal#close" data-modal-target="backdrop"></div>

  <!-- Modal Container -->
  <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
    <div class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-2xl" data-modal-target="container">
      <%= form_with(model: label, url: is_new ? labels_path : label_path(label), method: is_new ? :post : :patch, data: { turbo_frame: "label_modal" }, class: "contents") do |form| %>
        <!-- Modal Header -->
        <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
          <div class="flex items-center justify-between">
            <div class="flex-1">
              <h3 class="text-lg font-semibold text-gray-900" id="modal-title">
                <%= form_title %>
              </h3>
              <!-- Parent Label Breadcrumb -->
              <% if parent_label.present? %>
                <div class="mt-2 flex items-center text-sm text-gray-600">
                  <svg class="w-4 h-4 mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                  </svg>
                  <span>Parent: </span>
                  <% parent_label.ancestors.each do |ancestor| %>
                    <span class="mx-1 text-gray-400">/</span>
                    <span><%= ancestor.name %></span>
                  <% end %>
                  <span class="mx-1 text-gray-400">/</span>
                  <span class="font-medium"><%= parent_label.name %></span>
                </div>
              <% end %>
            </div>
            <%= link_to labels_path, data: { turbo_frame: "_top" }, class: "text-gray-400 hover:text-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded", aria_label: "Close" do %>
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            <% end %>
          </div>
        </div>

        <!-- Modal Body -->
        <div class="px-6 py-6 space-y-6">
          <!-- Error Messages -->
          <% if label.errors.any? %>
            <div class="rounded-lg bg-red-50 p-4 border border-red-200" role="alert">
              <div class="flex">
                <div class="flex-shrink-0">
                  <svg class="h-5 w-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div class="ml-3 flex-1">
                  <h3 class="text-sm font-medium text-red-800">
                    <%= pluralize(label.errors.count, "error") %> prevented this label from being saved:
                  </h3>
                  <ul class="mt-2 text-sm text-red-700 list-disc list-inside space-y-1">
                    <% label.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            </div>
          <% end %>

          <!-- Hidden Parent Field -->
          <% if parent_label.present? %>
            <%= form.hidden_field :parent_label_id, value: parent_label.id %>
          <% end %>

          <!-- Name Field -->
          <div>
            <%= form.label :name, class: "block text-sm font-medium text-gray-700" do %>
              Name <span class="text-red-600" aria-hidden="true">*</span>
              <span class="sr-only">(required)</span>
            <% end %>
            <%= form.text_field :name,
              required: true,
              autofocus: true,
              class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm #{'border-red-300' if label.errors[:name].any?}",
              placeholder: "e.g., Electronics",
              aria_required: "true",
              aria_invalid: label.errors[:name].any? ? "true" : "false",
              aria_describedby: label.errors[:name].any? ? "name-error" : nil %>
            <% if label.errors[:name].any? %>
              <p class="mt-1 text-sm text-red-600" id="name-error">
                <%= label.errors[:name].first %>
              </p>
            <% end %>
          </div>

          <!-- Code Field -->
          <div>
            <%= form.label :code, class: "block text-sm font-medium text-gray-700" do %>
              Code <span class="text-red-600" aria-hidden="true">*</span>
              <span class="sr-only">(required)</span>
            <% end %>
            <p class="mt-1 text-xs text-gray-500">
              Short identifier (lowercase, no spaces). Will be used in URLs and hierarchical codes.
            </p>
            <%= form.text_field :code,
              required: true,
              class: "mt-2 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm font-mono #{'border-red-300' if label.errors[:code].any?}",
              placeholder: "e.g., electronics",
              pattern: "[a-z0-9-]+",
              aria_required: "true",
              aria_invalid: label.errors[:code].any? ? "true" : "false",
              aria_describedby: label.errors[:code].any? ? "code-error" : "code-help" %>
            <% if label.errors[:code].any? %>
              <p class="mt-1 text-sm text-red-600" id="code-error">
                <%= label.errors[:code].first %>
              </p>
            <% else %>
              <p class="mt-1 text-xs text-gray-500" id="code-help">
                <% if parent_label.present? %>
                  Full code will be: <span class="font-mono font-semibold"><%= parent_label.full_code %>-[your-code]</span>
                <% else %>
                  This will be the root code for this label.
                <% end %>
              </p>
            <% end %>
          </div>

          <!-- Description Field -->
          <div>
            <%= form.label :description, class: "block text-sm font-medium text-gray-700" do %>
              Description
              <span class="text-gray-500 font-normal">(optional)</span>
            <% end %>
            <%= form.text_area :description,
              rows: 3,
              class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
              placeholder: "Add a description for this label..." %>
          </div>

          <!-- Label Type Field -->
          <div>
            <%= form.label :label_type, class: "block text-sm font-medium text-gray-700" do %>
              Label Type <span class="text-red-600" aria-hidden="true">*</span>
              <span class="sr-only">(required)</span>
            <% end %>
            <p class="mt-1 text-xs text-gray-500">
              Choose the type of categorization (e.g., category, tag, brand, collection)
            </p>
            <%= form.text_field :label_type,
              required: true,
              list: "label-types",
              class: "mt-2 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm #{'border-red-300' if label.errors[:label_type].any?}",
              placeholder: "e.g., category",
              aria_required: "true" %>
            <datalist id="label-types">
              <option value="category">
              <option value="tag">
              <option value="brand">
              <option value="collection">
              <option value="custom">
            </datalist>
            <% if label.errors[:label_type].any? %>
              <p class="mt-1 text-sm text-red-600">
                <%= label.errors[:label_type].first %>
              </p>
            <% end %>
          </div>

          <!-- Color Picker (stored in info JSONB) -->
          <div>
            <%= form.label :color, "Color (optional)", class: "block text-sm font-medium text-gray-700" %>
            <p class="mt-1 text-xs text-gray-500">
              Choose a color to visually identify this label
            </p>
            <div class="mt-2 flex items-center gap-3">
              <input
                type="color"
                name="label[info][color]"
                value="<%= label.info&.dig('color') || '#3b82f6' %>"
                class="h-10 w-20 rounded border border-gray-300 cursor-pointer focus:ring-2 focus:ring-blue-500 focus:outline-none"
                id="label_color">
              <div class="text-sm text-gray-600">
                <span class="font-mono" id="color-value"><%= label.info&.dig('color') || '#3b82f6' %></span>
              </div>
            </div>
          </div>

          <!-- Product Default Restriction -->
          <div>
            <%= form.label :product_default_restriction, class: "block text-sm font-medium text-gray-700" do %>
              Product Association Rule
              <span class="text-gray-500 font-normal">(optional)</span>
            <% end %>
            <p class="mt-1 text-xs text-gray-500">
              Control how products can be associated with this label
            </p>
            <%= form.select :product_default_restriction,
              [
                ['Allow (default)', 'allow'],
                ['Deny', 'deny']
              ],
              { include_blank: 'None' },
              class: "mt-2 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
          </div>
        </div>

        <!-- Modal Footer -->
        <div class="bg-gray-50 px-6 py-4 border-t border-gray-200 flex items-center justify-end gap-3">
          <%= link_to labels_path, data: { turbo_frame: "_top" }, class: "inline-flex items-center justify-center font-medium rounded-lg transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 px-4 py-2 text-sm bg-white hover:bg-gray-50 focus:ring-blue-500 text-gray-700 border border-gray-300" do %>
            Cancel
          <% end %>

          <%= render Ui::ButtonComponent.new(type: "submit", variant: :primary) do %>
            <%= submit_text %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Color picker value updater -->
<script>
  document.addEventListener('turbo:load', () => {
    const colorInput = document.getElementById('label_color');
    const colorValue = document.getElementById('color-value');

    if (colorInput && colorValue) {
      colorInput.addEventListener('input', (e) => {
        colorValue.textContent = e.target.value;
      });
    }
  });
</script>
