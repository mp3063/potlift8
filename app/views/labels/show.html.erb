<% content_for :page_header do %>
  <!-- Breadcrumb Navigation -->
  <nav class="mb-4" aria-label="Breadcrumb">
    <ol class="flex items-center space-x-2 text-sm">
      <li>
        <%= link_to labels_path, class: "text-gray-500 hover:text-gray-700 transition-colors" do %>
          All Labels
        <% end %>
      </li>
      <% @label.ancestors.each do |ancestor| %>
        <li class="flex items-center">
          <svg class="flex-shrink-0 w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
          </svg>
          <%= link_to ancestor.name, label_path(ancestor), class: "ml-2 text-gray-500 hover:text-gray-700 transition-colors" %>
        </li>
      <% end %>
      <li class="flex items-center">
        <svg class="flex-shrink-0 w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
        </svg>
        <span class="ml-2 text-gray-700 font-medium" aria-current="page"><%= @label.name %></span>
      </li>
    </ol>
  </nav>

  <!-- Page Header -->
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <!-- Color Indicator -->
      <% if @label.info&.dig('color').present? %>
        <div
          class="w-8 h-8 rounded-full border-2 border-gray-300 shadow-sm"
          style="background-color: <%= @label.info['color'] %>;"
          aria-hidden="true">
        </div>
      <% end %>

      <div>
        <h1 class="text-2xl font-bold text-gray-900"><%= @label.name %></h1>
        <p class="mt-1 text-sm text-gray-600">
          Code: <span class="font-mono"><%= @label.code %></span>
          <% if @label.label_type.present? %>
            · Type: <span class="capitalize"><%= @label.label_type %></span>
          <% end %>
        </p>
        <% if @label.description.present? %>
          <p class="mt-2 text-sm text-gray-700"><%= @label.description %></p>
        <% end %>
      </div>
    </div>

    <div class="flex gap-3">
      <%= render Ui::ButtonComponent.new(
        variant: :secondary,
        onclick: "window.location.href='#{new_label_path(parent_id: @label.id)}'"
      ) do %>
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Add Sublabel
      <% end %>

      <%= render Ui::ButtonComponent.new(
        variant: :secondary,
        onclick: "window.location.href='#{edit_label_path(@label)}'"
      ) do %>
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
        Edit
      <% end %>

      <%= button_to label_path(@label),
        method: :delete,
        form: {
          data: { turbo_confirm: "Are you sure you want to delete '#{@label.name}'?#{@sublabels.any? ? ' This label has sublabels.' : ''}#{@label.products.any? ? " This label is assigned to #{@label.products.size} products." : ''}" }
        },
        class: "inline-flex items-center justify-center font-medium rounded-lg transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 px-4 py-2 text-sm bg-red-600 hover:bg-red-700 focus:ring-red-500 text-white" do %>
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
        Delete
      <% end %>
    </div>
  </div>
<% end %>

<div class="space-y-8">
  <!-- Stats -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- Direct Products -->
    <%= render Ui::CardComponent.new(hover: true, padding: :lg) do %>
      <div class="text-center">
        <div class="flex justify-center mb-2">
          <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
          </svg>
        </div>
        <div class="text-3xl font-bold text-gray-900"><%= @label.products.size %></div>
        <div class="text-sm text-gray-600 mt-1">Direct Products</div>
      </div>
    <% end %>

    <!-- Total Products (including sublabels) -->
    <% total_products = @label.all_products_including_sublabels.size %>
    <%= render Ui::CardComponent.new(hover: true, padding: :lg) do %>
      <div class="text-center">
        <div class="flex justify-center mb-2">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <div class="text-3xl font-bold text-gray-900"><%= total_products %></div>
        <div class="text-sm text-gray-600 mt-1">Total Products</div>
      </div>
    <% end %>

    <!-- Sublabels -->
    <%= render Ui::CardComponent.new(hover: true, padding: :lg) do %>
      <div class="text-center">
        <div class="flex justify-center mb-2">
          <svg class="w-8 h-8 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
          </svg>
        </div>
        <div class="text-3xl font-bold text-gray-900"><%= @sublabels.size %></div>
        <div class="text-sm text-gray-600 mt-1">Sublabels</div>
      </div>
    <% end %>
  </div>

  <!-- Sublabels Section -->
  <% if @sublabels.any? %>
    <%= render Ui::CardComponent.new do |card| %>
      <% card.with_header do %>
        <h2 class="text-lg font-semibold text-gray-900">Sublabels</h2>
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @sublabels.each do |sublabel| %>
          <%= link_to label_path(sublabel), class: "block p-4 rounded-lg border border-gray-200 hover:border-blue-500 hover:shadow-md transition-all" do %>
            <div class="flex items-start gap-3">
              <!-- Color Indicator -->
              <% if sublabel.info&.dig('color').present? %>
                <div
                  class="flex-shrink-0 w-6 h-6 rounded-full border border-gray-300"
                  style="background-color: <%= sublabel.info['color'] %>;"
                  aria-hidden="true">
                </div>
              <% end %>

              <div class="flex-1 min-w-0">
                <h3 class="font-medium text-gray-900"><%= sublabel.name %></h3>
                <p class="text-xs text-gray-500 font-mono mt-0.5"><%= sublabel.code %></p>
                <div class="flex items-center gap-3 mt-2 text-xs text-gray-600">
                  <span title="Products"><%= sublabel.products.size %> products</span>
                  <% if sublabel.sublabels.any? %>
                    <span title="Sublabels"><%= sublabel.sublabels.size %> sublabels</span>
                  <% end %>
                </div>
              </div>

              <svg class="flex-shrink-0 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <!-- Products Section -->
  <%= render Ui::CardComponent.new do |card| %>
    <% card.with_header do %>
      <h2 class="text-lg font-semibold text-gray-900">
        Products
        <span class="ml-2 text-sm font-normal text-gray-600">(<%= @label.products.size %>)</span>
      </h2>
    <% end %>

    <% if @products.any? %>
      <!-- Simple Products Table -->
      <div class="overflow-hidden border border-gray-200 rounded-lg">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">
                SKU
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">
                Name
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">
                Status
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">
                Inventory
              </th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-700 uppercase tracking-wider">
                Actions
              </th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @products.each do |product| %>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                  <%= link_to product.sku, product_path(product), class: "text-blue-600 hover:text-blue-900" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                  <%= product.name %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <%= render Ui::BadgeComponent.new(
                    variant: product.product_status == 'active' ? :success : :gray,
                    size: :sm
                  ) do %>
                    <%= product.product_status&.titleize %>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                  <%= product.total_inventory || 0 %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <%= link_to product_path(product), class: "text-blue-600 hover:text-blue-900" do %>
                    View
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if @pagy && @pagy.pages > 1 %>
        <div class="mt-4">
          <%== pagy_nav(@pagy) %>
        </div>
      <% end %>
    <% else %>
      <!-- No Products -->
      <div class="text-center py-8">
        <svg class="mx-auto h-10 w-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
        </svg>
        <h3 class="mt-2 text-sm font-semibold text-gray-900">No products</h3>
        <p class="mt-1 text-sm text-gray-500">
          No products are currently assigned to this label.
        </p>
      </div>
    <% end %>
  <% end %>
</div>
