<%= turbo_frame_tag "modal" do %>
  <%= render Ui::ModalComponent.new(size: :lg, id: "import-products-modal") do |modal| %>
  <% modal.with_header do %>
    <h3 class="text-lg font-semibold text-gray-900">Import Products to <%= @catalog.name %></h3>
  <% end %>

  <div class="space-y-6">
    <!-- Instructions -->
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3 flex-1">
          <h3 class="text-sm font-medium text-blue-800">CSV Import Instructions</h3>
          <div class="mt-2 text-sm text-blue-700">
            <ul class="list-disc list-inside space-y-1">
              <li>Upload a CSV file with product SKUs to add to this catalog</li>
              <li>Products already in the catalog will be updated (if state/priority specified)</li>
              <li>Download the template below to see the required format</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Template Download -->
    <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg border border-gray-200">
      <div>
        <p class="text-sm font-medium text-gray-900">Need a template?</p>
        <p class="text-sm text-gray-600">Download a CSV template with example data</p>
      </div>
      <%= link_to catalog_imports_template_path(@catalog.code), class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors duration-200" do %>
        <svg class="-ml-1 mr-2 h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
        </svg>
        Download Template
      <% end %>
    </div>

    <!-- CSV Format Reference -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="px-4 py-3 bg-gray-50 border-b border-gray-200">
        <h4 class="text-sm font-medium text-gray-900">CSV Format</h4>
      </div>
      <div class="px-4 py-3">
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Column</th>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Required</th>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Description</th>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Example</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <tr>
                <td class="px-3 py-2 font-mono text-xs">product_sku</td>
                <td class="px-3 py-2">
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">Required</span>
                </td>
                <td class="px-3 py-2 text-gray-700">Product SKU to add to catalog</td>
                <td class="px-3 py-2 font-mono text-xs text-gray-600">PROD-001</td>
              </tr>
              <tr>
                <td class="px-3 py-2 font-mono text-xs">catalog_item_state</td>
                <td class="px-3 py-2">
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">Optional</span>
                </td>
                <td class="px-3 py-2 text-gray-700">State: active or inactive (default: active)</td>
                <td class="px-3 py-2 font-mono text-xs text-gray-600">active</td>
              </tr>
              <tr>
                <td class="px-3 py-2 font-mono text-xs">priority</td>
                <td class="px-3 py-2">
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">Optional</span>
                </td>
                <td class="px-3 py-2 text-gray-700">Priority for ordering (higher = first)</td>
                <td class="px-3 py-2 font-mono text-xs text-gray-600">100</td>
              </tr>
              <tr>
                <td class="px-3 py-2 font-mono text-xs">price_override</td>
                <td class="px-3 py-2">
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">Optional</span>
                </td>
                <td class="px-3 py-2 text-gray-700">Catalog-specific price override</td>
                <td class="px-3 py-2 font-mono text-xs text-gray-600">19.99</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- File Upload Form -->
    <%= form_with url: catalog_imports_path(@catalog.code), method: :post, multipart: true, id: "import-products-form", data: { controller: "file-upload" } do |f| %>
      <div class="border-2 border-dashed border-gray-300 rounded-lg p-6 hover:border-blue-400 transition-colors duration-200" data-file-upload-target="dropzone">
        <div class="text-center">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
          </svg>
          <div class="mt-4">
            <%= f.file_field :file,
                accept: ".csv",
                required: true,
                class: "sr-only",
                data: {
                  action: "change->file-upload#handleFileSelect",
                  file_upload_target: "fileInput"
                },
                id: "catalog-import-file" %>
            <label for="catalog-import-file" class="cursor-pointer">
              <span class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-blue-500 transition-colors duration-200">
                Select CSV File
              </span>
            </label>
            <p class="mt-2 text-xs text-gray-500">or drag and drop</p>
          </div>
          <p class="mt-2 text-xs text-gray-500">CSV files only, max 10MB</p>

          <!-- Selected File Display -->
          <div data-file-upload-target="fileName" class="mt-4 hidden">
            <div class="inline-flex items-center px-3 py-2 bg-blue-50 border border-blue-200 rounded-lg text-sm">
              <svg class="h-5 w-5 text-blue-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd" />
              </svg>
              <span data-file-upload-target="fileNameText" class="text-blue-700 font-medium"></span>
            </div>
          </div>
        </div>
      </div>

      <% modal.with_footer do %>
        <div class="flex items-center justify-end gap-3 w-full">
          <%= render Ui::ButtonComponent.new(
            variant: :secondary,
            data: { action: "click->modal#close" }
          ) do %>
            Cancel
          <% end %>

          <%= render Ui::ButtonComponent.new(
            variant: :primary,
            type: :submit,
            form: "import-products-form"
          ) do %>
            <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
            </svg>
            Import Products
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
  <% end %>
<% end %>
