<%# Turbo Stream response for product search %>
<%# Updates the search results container with matching products %>

<%= turbo_stream.update "bundle_composer_search_results" do %>
  <% if @products.any? %>
    <div class="space-y-2">
      <% @products.each do |product| %>
        <div class="border border-gray-200 rounded-lg p-4 hover:bg-gray-50 cursor-pointer"
             data-product-id="<%= product.id %>"
             data-product-type="<%= product.product_type %>"
             data-product-sku="<%= product.sku %>"
             data-product-name="<%= product.name %>">
          <div class="flex justify-between items-start">
            <div>
              <h4 class="font-medium text-gray-900"><%= product.name %></h4>
              <p class="text-sm text-gray-500"><%= product.sku %></p>
              <% if product.product_type_configurable? %>
                <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-blue-100 text-blue-800 mt-1">
                  Configurable (<%= product.subproducts.count %> variants)
                </span>
              <% else %>
                <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-green-100 text-green-800 mt-1">
                  Sellable
                </span>
              <% end %>
            </div>
            <button type="button"
                    class="px-3 py-1 text-sm font-medium text-blue-600 hover:text-blue-700 hover:bg-blue-50 rounded">
              Add
            </button>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-8 text-gray-500">
      <% if params[:q].present? %>
        No products found matching "<%= params[:q] %>"
      <% else %>
        Search for products to add to bundle
      <% end %>
    </div>
  <% end %>
<% end %>
