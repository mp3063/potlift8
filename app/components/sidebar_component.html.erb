<!-- Static sidebar for desktop -->
<div class="hidden lg:fixed lg:inset-y-0 lg:z-50 lg:flex lg:w-72 lg:flex-col">
  <div class="flex grow flex-col gap-y-5 overflow-y-auto bg-gray-900 px-6 pb-4">
    <div class="flex h-16 shrink-0 items-center">
      <span class="text-white text-2xl font-bold">Potlift8</span>
    </div>

    <nav class="flex flex-1 flex-col" aria-label="Main navigation">
      <ul role="list" class="flex flex-1 flex-col gap-y-7">
        <li>
          <ul role="list" class="-mx-2 space-y-1">
            <% items.each do |item| %>
              <li>
                <%= link_to item[:path], class: item_classes(item), aria: { current: item_active?(item) ? 'page' : nil } do %>
                  <svg class="<%= icon_classes(item) %>" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                    <%= item[:icon_path].html_safe %>
                  </svg>
                  <%= item[:name] %>
                <% end %>
              </li>
            <% end %>
          </ul>
        </li>

        <li class="mt-auto">
          <div class="rounded-lg bg-gray-800 p-3">
            <p class="text-xs font-medium text-white"><%= company.name %></p>
            <p class="text-xs text-gray-400">Current workspace</p>
          </div>
        </li>
      </ul>
    </nav>
  </div>
</div>

<!-- Mobile sidebar -->
<div class="lg:hidden" data-controller="mobile-sidebar">
  <div class="relative z-50 hidden" data-mobile-sidebar-target="overlay" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-gray-900/80" data-action="click->mobile-sidebar#close"></div>

    <div class="fixed inset-0 flex">
      <div class="relative mr-16 flex w-full max-w-xs flex-1">
        <div class="absolute left-full top-0 flex w-16 justify-center pt-5">
          <button type="button" class="-m-2.5 p-2.5" data-action="click->mobile-sidebar#close">
            <span class="sr-only">Close sidebar</span>
            <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <div class="flex grow flex-col gap-y-5 overflow-y-auto bg-gray-900 px-6 pb-4 ring-1 ring-white/10">
          <div class="flex h-16 shrink-0 items-center">
            <span class="text-white text-2xl font-bold">Potlift8</span>
          </div>

          <nav class="flex flex-1 flex-col" aria-label="Main navigation">
            <ul role="list" class="flex flex-1 flex-col gap-y-7">
              <li>
                <ul role="list" class="-mx-2 space-y-1">
                  <% items.each do |item| %>
                    <li>
                      <%= link_to item[:path], class: item_classes(item), aria: { current: item_active?(item) ? 'page' : nil }, data: { action: 'click->mobile-sidebar#close' } do %>
                        <svg class="<%= icon_classes(item) %>" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                          <%= item[:icon_path].html_safe %>
                        </svg>
                        <%= item[:name] %>
                      <% end %>
                    </li>
                  <% end %>
                </ul>
              </li>

              <li class="mt-auto">
                <div class="rounded-lg bg-gray-800 p-3">
                  <p class="text-xs font-medium text-white"><%= company.name %></p>
                  <p class="text-xs text-gray-400">Current workspace</p>
                </div>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    </div>
  </div>
</div>
