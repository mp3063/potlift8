<%= helpers.form_with model: product, url: url, method: method, data: { controller: "product-form", turbo: true }, class: "space-y-6" do |form| %>
  <% if product.errors.any? %>
    <div class="rounded-md bg-red-50 p-4" role="alert">
      <div class="flex">
        <div class="flex-shrink-0">
          <%= x_circle_icon %>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            There <%= product.errors.count == 1 ? 'was' : 'were' %> <%= helpers.pluralize(product.errors.count, "error") %> with your submission:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul role="list" class="list-disc space-y-1 pl-5">
              <% product.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-6">
    <!-- SKU -->
    <div class="sm:col-span-3">
      <%= form.label :sku, "SKU", class: "block text-sm font-medium leading-6 text-gray-900" %>
      <div class="mt-2">
        <%= form.text_field :sku,
            class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 #{product.errors[:sku].any? ? 'ring-red-300 focus:ring-red-600' : ''}",
            placeholder: "Auto-generated if left blank",
            data: {
              product_form_target: "sku",
              action: "blur->product-form#validateSku"
            },
            aria: {
              describedby: "sku-description",
              invalid: product.errors[:sku].any?
            } %>
      </div>
      <% if product.errors[:sku].any? %>
        <p class="mt-2 text-sm text-red-600" id="sku-error" role="alert"><%= product.errors[:sku].first %></p>
      <% else %>
        <p class="mt-2 text-sm text-gray-500" id="sku-description">Leave blank to auto-generate a unique SKU</p>
      <% end %>
    </div>

    <!-- Product Type -->
    <div class="sm:col-span-3">
      <%= form.label :product_type, "Product Type", class: "block text-sm font-medium leading-6 text-gray-900" %>
      <div class="mt-2">
        <%= form.select :product_type,
            product_type_options,
            { prompt: "Select a product type" },
            class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 #{product.errors[:product_type].any? ? 'ring-red-300 focus:ring-red-600' : ''}",
            data: {
              product_form_target: "productType",
              action: "change->product-form#handleTypeChange"
            },
            aria: {
              invalid: product.errors[:product_type].any?
            } %>
      </div>
      <% if product.errors[:product_type].any? %>
        <p class="mt-2 text-sm text-red-600" role="alert"><%= product.errors[:product_type].first %></p>
      <% end %>
    </div>

    <!-- Name -->
    <div class="sm:col-span-6">
      <%= form.label :name, class: "block text-sm font-medium leading-6 text-gray-900" %>
      <div class="mt-2">
        <%= form.text_field :name,
            class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 #{product.errors[:name].any? ? 'ring-red-300 focus:ring-red-600' : ''}",
            placeholder: "Enter product name",
            required: true,
            aria: {
              invalid: product.errors[:name].any?
            } %>
      </div>
      <% if product.errors[:name].any? %>
        <p class="mt-2 text-sm text-red-600" role="alert"><%= product.errors[:name].first %></p>
      <% end %>
    </div>

    <!-- Description -->
    <div class="sm:col-span-6">
      <%= form.label :description, class: "block text-sm font-medium leading-6 text-gray-900" %>
      <div class="mt-2">
        <%= form.text_area :description,
            rows: 4,
            class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6",
            placeholder: "Enter product description",
            aria: {
              describedby: "description-hint"
            } %>
      </div>
      <p class="mt-2 text-sm text-gray-500" id="description-hint">Optional product description</p>
    </div>

    <!-- Active Status -->
    <div class="sm:col-span-6">
      <div class="relative flex gap-x-3">
        <div class="flex h-6 items-center">
          <%= form.check_box :active,
              class: "h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600",
              aria: {
                describedby: "active-description"
              } %>
        </div>
        <div class="text-sm leading-6">
          <%= form.label :active, class: "font-medium text-gray-900" %>
          <p class="text-gray-500" id="active-description">Product is active and available for use</p>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-6 flex items-center justify-end gap-x-6">
    <%= helpers.link_to "Cancel", helpers.products_path, class: "text-sm font-semibold leading-6 text-gray-900 hover:text-gray-700" %>
    <%= form.submit class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 disabled:opacity-50 disabled:cursor-not-allowed" %>
  </div>
<% end %>
