<%= render Ui::CardComponent.new do |card| %>
  <% card.with_header do %>
    <h3 class="text-base font-semibold leading-6 text-gray-900">Attributes</h3>
  <% end %>

  <% card.with_action do %>
    <%= helpers.link_to "Manage Attributes",
        helpers.product_attributes_path,
        class: "text-sm font-medium text-blue-600 hover:text-blue-500" %>
  <% end %>

  <% if has_attributes? %>
    <div class="space-y-6">
      <% grouped_attributes.each do |group, group_attributes| %>
        <div>
          <h4 class="text-sm font-medium text-gray-700 mb-3">
            <%= group&.name || "General" %>
          </h4>
          <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2">
            <% group_attributes.each do |attribute, value| %>
              <div class="sm:col-span-1">
                <dt class="text-sm font-medium text-gray-500">
                  <%= attribute.name %>
                </dt>
                <dd class="mt-1 text-sm text-gray-900">
                  <%= helpers.turbo_frame_tag helpers.dom_id(attribute, :value) do %>
                    <div class="group relative" data-controller="inline-editor" data-inline-editor-url-value="<%= helpers.product_attribute_value_path(product, attribute) %>">
                      <div class="flex items-center justify-between" data-inline-editor-target="display">
                        <span><%= value&.value || "—" %></span>
                        <%= helpers.button_tag type: "button",
                            class: "ml-2 opacity-0 group-hover:opacity-100 transition-opacity text-gray-400 hover:text-gray-600",
                            data: { action: "click->inline-editor#edit" },
                            aria: { label: "Edit #{attribute.name}" } do %>
                          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                          </svg>
                        <% end %>
                      </div>

                      <div class="hidden" data-inline-editor-target="editor">
                        <%= helpers.form_with url: helpers.product_attribute_value_path(product, attribute),
                                      method: :patch,
                                      data: {
                                        inline_editor_target: "form",
                                        action: "turbo:submit-end->inline-editor#handleSubmit"
                                      } do |form| %>
                          <%= form.text_field :value,
                              value: value&.value,
                              class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>

                          <div class="mt-2 flex gap-x-2">
                            <%= form.submit "Save",
                                class: "rounded-md bg-blue-600 px-2 py-1 text-xs font-semibold text-white shadow-sm hover:bg-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
                            <%= helpers.button_tag "Cancel",
                                type: "button",
                                class: "rounded-md bg-white px-2 py-1 text-xs font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2",
                                data: { action: "click->inline-editor#cancel" } %>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </dd>
              </div>
            <% end %>
          </dl>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-6">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <p class="mt-2 text-sm text-gray-500">No attributes defined for this product type.</p>
    </div>
  <% end %>
<% end %>
