<%= helpers.turbo_frame_tag "products_table" do %>
  <div class="overflow-hidden border border-gray-200 rounded-lg shadow-sm">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-6 py-3 text-left">
            <input type="checkbox" class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-600" data-action="change->bulk-actions#toggleAll" aria-label="Select all products">
          </th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">
            <%= sort_link('sku', 'SKU') %>
            <%= sort_icon('sku') %>
          </th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">
            <%= sort_link('name', 'Name') %>
            <%= sort_icon('name') %>
          </th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">
            Type
          </th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">
            Labels
          </th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">
            Inventory
          </th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">
            Status
          </th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">
            <%= sort_link('created_at', 'Created') %>
            <%= sort_icon('created_at') %>
          </th>
          <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-700 uppercase tracking-wider">
            Actions
          </th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% if products.any? %>
          <% products.each do |product| %>
            <tr class="hover:bg-gray-50 transition-colors" data-product-id="<%= product.id %>">
              <td class="px-6 py-4 whitespace-nowrap">
                <input
                  type="checkbox"
                  class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-600"
                  data-bulk-actions-target="checkbox"
                  data-action="change->bulk-actions#toggleCheckbox"
                  value="<%= product.id %>"
                  aria-label="Select <%= product.name %>"
                >
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                <%= helpers.link_to product.sku, helpers.product_path(product), class: "text-blue-600 hover:text-blue-900", data: { turbo_frame: "_top" } %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                <%= product.name %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= type_badge(product) %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-700">
                <div class="flex flex-wrap gap-1">
                  <% labels_to_show = product.labels.take(3) %>
                  <% total_labels = product.labels.size %>
                  <% labels_to_show.each do |label| %>
                    <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-800">
                      <%= label.name %>
                    </span>
                  <% end %>
                  <% if total_labels > 3 %>
                    <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-800">
                      +<%= total_labels - 3 %>
                    </span>
                  <% end %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                <%= product.total_inventory %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= status_badge(product) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                <%= product.created_at.strftime('%Y-%m-%d') %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <div class="flex justify-end gap-2">
                  <%= helpers.link_to helpers.edit_product_path(product), class: "text-blue-600 hover:text-blue-900 inline-flex items-center", title: "Edit #{product.name}", data: { turbo_frame: "_top" } do %>
                    <%= edit_icon %>
                    <span class="sr-only">Edit</span>
                  <% end %>

                  <%= helpers.link_to helpers.duplicate_product_path(product), data: { turbo_method: :post }, class: "text-gray-600 hover:text-gray-900 inline-flex items-center", title: "Duplicate #{product.name}" do %>
                    <%= duplicate_icon %>
                    <span class="sr-only">Duplicate</span>
                  <% end %>

                  <%= helpers.button_to helpers.product_path(product),
                      method: :delete,
                      form: { data: { turbo_confirm: "Are you sure you want to delete #{product.name}?" } },
                      class: "text-red-600 hover:text-red-900 inline-flex items-center",
                      title: "Delete #{product.name}" do %>
                    <%= trash_icon %>
                    <span class="sr-only">Delete</span>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="9" class="text-center py-12">
              <%= empty_state_icon %>
              <h3 class="mt-2 text-sm font-semibold text-gray-900"><%= empty_state_title %></h3>
              <p class="mt-1 text-sm text-gray-500"><%= empty_state_description %></p>
              <% if show_new_product_button? %>
                <div class="mt-6">
                  <%= helpers.link_to helpers.new_product_path, data: { turbo_frame: "_top" }, class: "inline-flex items-center rounded-md bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
                    <%= plus_icon %>
                    <span class="ml-1.5">New Product</span>
                  <% end %>
                </div>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <!-- Pagination -->
    <%= render Shared::PaginationComponent.new(pagy: pagy, variant: :table) if pagy %>
  </div>
<% end %>
