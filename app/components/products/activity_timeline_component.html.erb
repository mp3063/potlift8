<%= render Ui::CardComponent.new do |card| %>
  <% card.with_header do %>
    <h3 class="text-base font-semibold leading-6 text-gray-900">Recent Activity</h3>
  <% end %>

  <% if has_activities? %>
    <div class="flow-root">
      <ul role="list" class="-mb-8">
        <% recent_activities.each_with_index do |activity, index| %>
          <li>
            <div class="relative pb-8">
              <!-- Connecting line (except for last item) -->
              <% if index < recent_activities.length - 1 %>
                <span class="absolute left-4 top-4 -ml-px h-full w-0.5 bg-gray-200" aria-hidden="true"></span>
              <% end %>

              <div class="relative flex space-x-3">
                <!-- Icon -->
                <div>
                  <span class="h-8 w-8 rounded-full bg-gray-50 flex items-center justify-center ring-8 ring-white">
                    <svg class="h-5 w-5 <%= activity_color(activity[:type]) %>" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="<%= activity_icon_path(activity[:type]) %>" />
                    </svg>
                  </span>
                </div>

                <!-- Content -->
                <div class="flex min-w-0 flex-1 justify-between space-x-4 pt-1.5">
                  <div>
                    <p class="text-sm text-gray-900">
                      <%= activity[:description] %>
                      <% if activity[:user].present? %>
                        <span class="font-medium text-gray-900">by <%= activity[:user] %></span>
                      <% end %>
                    </p>
                  </div>
                  <div class="whitespace-nowrap text-right text-xs text-gray-500" title="<%= activity[:timestamp].strftime('%B %d, %Y at %I:%M %p') %>">
                    <%= time_ago_in_words(activity[:timestamp]) %> ago
                  </div>
                </div>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>

    <div class="border-t border-gray-100 px-4 py-3 sm:px-6">
      <%= link_to product_versions_path(product),
          class: "text-sm font-medium text-blue-600 hover:text-blue-500 flex items-center justify-between" do %>
        <span>View full history</span>
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
        </svg>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-6">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <p class="mt-2 text-sm text-gray-500">No recent activity</p>
    </div>
  <% end %>
<% end %>
