<%= render Ui::CardComponent.new do |card| %>
  <% card.with_header do %>
    <h3 class="text-base font-semibold leading-6 text-gray-900">Basic Information</h3>
  <% end %>

  <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
    <!-- SKU -->
    <div class="sm:col-span-1">
      <dt class="text-sm font-medium text-gray-500">SKU</dt>
      <dd class="mt-1 text-sm text-gray-900 font-mono"><%= product.sku %></dd>
    </div>

    <!-- EAN -->
    <div class="sm:col-span-1">
      <dt class="text-sm font-medium text-gray-500">EAN</dt>
      <dd class="mt-1 text-sm text-gray-900 font-mono"><%= product.ean || "—" %></dd>
    </div>

    <!-- Product Type -->
    <div class="sm:col-span-1">
      <dt class="text-sm font-medium text-gray-500">Product Type</dt>
      <dd class="mt-1">
        <%= render Ui::BadgeComponent.new(variant: type_badge_variant, size: :md) do %>
          <%= product_type_label %>
        <% end %>
      </dd>
    </div>

    <!-- Status -->
    <div class="sm:col-span-1">
      <dt class="text-sm font-medium text-gray-500">Status</dt>
      <dd class="mt-1">
        <%= render Ui::BadgeComponent.new(variant: status_badge_variant, size: :md, dot: true) do %>
          <%= product_status_label %>
        <% end %>
      </dd>
    </div>

    <!-- Restock Level -->
    <div class="sm:col-span-1">
      <dt class="text-sm font-medium text-gray-500">Restock Level</dt>
      <dd class="mt-1 text-sm text-gray-900">
        <%= number_with_delimiter(product.info&.dig('restock_level') || 0) %>
        <span class="text-xs text-gray-500">(low stock threshold)</span>
      </dd>
    </div>

    <!-- Name -->
    <div class="sm:col-span-2">
      <dt class="text-sm font-medium text-gray-500">Product Name</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= product.name %></dd>
    </div>

    <!-- Description -->
    <% if product.description.present? %>
      <div class="sm:col-span-2">
        <dt class="text-sm font-medium text-gray-500">Description</dt>
        <dd class="mt-1 text-sm text-gray-900 whitespace-pre-wrap"><%= product.description %></dd>
      </div>
    <% end %>
  </dl>
<% end %>
