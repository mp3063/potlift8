<%= render Ui::CardComponent.new do |card| %>
  <% card.with_header do %>
    <h3 class="text-base font-semibold leading-6 text-gray-900">Status</h3>
  <% end %>

  <dl class="space-y-3">
    <!-- Active Status -->
    <div class="flex items-center justify-between">
      <dt class="text-sm font-medium text-gray-500">Active Status</dt>
      <dd class="flex items-center text-sm font-semibold">
        <svg class="h-5 w-5 mr-1 <%= status_color %>" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <% if product.active? %>
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
          <% else %>
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
          <% end %>
        </svg>
        <span class="<%= status_text_color %>"><%= status_text %></span>
      </dd>
    </div>

    <!-- Product Type -->
    <div class="flex items-center justify-between">
      <dt class="text-sm font-medium text-gray-500">Product Type</dt>
      <dd class="text-sm text-gray-900">
        <%= product_type_label %>
      </dd>
    </div>

    <!-- Last Updated -->
    <div class="flex items-center justify-between">
      <dt class="text-sm font-medium text-gray-500">Last Updated</dt>
      <dd class="text-sm text-gray-900" title="<%= product.updated_at.strftime('%B %d, %Y at %I:%M %p') %>">
        <%= time_ago_in_words(product.updated_at) %> ago
      </dd>
    </div>
  </dl>

  <!-- Toggle Button -->
  <div class="mt-6">
    <%= button_to toggle_active_product_path(product),
        method: :patch,
        class: toggle_button_classes do %>
      <%= toggle_button_text %>
    <% end %>
  </div>
<% end %>
