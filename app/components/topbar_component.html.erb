<div class="sticky top-0 z-40 flex h-16 shrink-0 items-center gap-x-4 border-b border-gray-200 bg-white px-4 shadow-sm sm:gap-x-6 sm:px-6 lg:px-8">
  <!-- Mobile menu button -->
  <button type="button" class="-m-2.5 p-2.5 text-gray-700 lg:hidden" data-action="click->mobile-sidebar#open">
    <span class="sr-only">Open sidebar</span>
    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
    </svg>
  </button>

  <div class="h-6 w-px bg-gray-200 lg:hidden" aria-hidden="true"></div>

  <div class="flex flex-1 gap-x-4 self-stretch lg:gap-x-6">
    <!-- Global search -->
    <form class="relative flex flex-1" action="/search" method="get" data-controller="global-search">
      <label for="search-field" class="sr-only">Search</label>
      <svg class="pointer-events-none absolute inset-y-0 left-0 h-full w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
      </svg>
      <input
        id="search-field"
        class="block h-full w-full border-0 py-0 pl-8 pr-0 text-gray-900 placeholder:text-gray-400 focus:ring-0 sm:text-sm"
        placeholder="Search... (⌘K)"
        type="search"
        name="q"
        data-global-search-target="input"
        data-action="keydown->global-search#handleKeydown"
      >
    </form>

    <div class="flex items-center gap-x-4 lg:gap-x-6">
      <!-- Company selector (if multiple companies) -->
      <% if multiple_companies? %>
        <div class="relative" data-controller="dropdown">
          <button type="button" class="flex items-center gap-x-1 text-sm font-semibold leading-6 text-gray-900" data-action="click->dropdown#toggle" aria-expanded="false" aria-haspopup="true">
            <span><%= company.name %></span>
            <svg class="h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
            </svg>
          </button>

          <div class="hidden absolute right-0 z-10 mt-2.5 w-48 origin-top-right rounded-md bg-white py-2 shadow-lg ring-1 ring-gray-900/5 focus:outline-none" data-dropdown-target="menu" role="menu" aria-orientation="vertical">
            <% companies.each do |comp| %>
              <%= button_to switch_company_path(comp),
                  method: :post,
                  class: "block w-full text-left px-3 py-1 text-sm leading-6 text-gray-900 hover:bg-gray-50 #{'bg-gray-50 font-semibold' if comp.id == company.id}",
                  role: "menuitem" do %>
                <%= comp.name %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- User menu -->
      <div class="relative" data-controller="dropdown">
        <button type="button" class="-m-1.5 flex items-center p-1.5" data-action="click->dropdown#toggle" aria-expanded="false" aria-haspopup="true">
          <span class="sr-only">Open user menu</span>
          <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gray-500 text-white text-sm font-medium">
            <%= user_initials %>
          </div>
          <span class="hidden lg:flex lg:items-center">
            <span class="ml-4 text-sm font-semibold leading-6 text-gray-900" aria-hidden="true"><%= user[:name] %></span>
            <svg class="ml-2 h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
            </svg>
          </span>
        </button>

        <div class="hidden absolute right-0 z-10 mt-2.5 w-48 origin-top-right rounded-md bg-white py-1 shadow-lg ring-1 ring-gray-900/5 focus:outline-none" data-dropdown-target="menu" role="menu" aria-orientation="vertical">
          <%= link_to "Profile", "#", class: "block px-3 py-1 text-sm leading-6 text-gray-900 hover:bg-gray-50", role: "menuitem" %>
          <%= link_to "Settings", "#", class: "block px-3 py-1 text-sm leading-6 text-gray-900 hover:bg-gray-50", role: "menuitem" %>
          <hr class="my-1 border-gray-200">
          <%= link_to "Sign out", auth_logout_path, data: { turbo_method: :delete }, class: "block px-3 py-1 text-sm leading-6 text-gray-900 hover:bg-gray-50", role: "menuitem" %>
        </div>
      </div>
    </div>
  </div>
</div>
