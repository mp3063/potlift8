<%= render Ui::CardComponent.new do |card| %>
  <% card.with_header do %>
    <div class="flex items-center gap-2">
      <svg class="h-5 w-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h3 class="text-base font-semibold leading-6 text-gray-900">Shopify Ecosystem</h3>
    </div>
  <% end %>

  <div class="space-y-5">
    <%# Connection status %>
    <div class="flex items-center justify-between">
      <%= render Ui::BadgeComponent.new(variant: :success, dot: true) do %>
        Connected
      <% end %>
      <% if shopify_domain.present? %>
        <span class="text-sm text-gray-500 font-mono truncate ml-2"><%= shopify_domain %></span>
      <% end %>
    </div>

    <%# Quick Links %>
    <div class="flex flex-col sm:flex-row gap-3">
      <% if shopify_admin_url.present? %>
        <a href="<%= shopify_admin_url %>"
           target="_blank"
           rel="noopener noreferrer"
           class="flex-1 inline-flex items-center justify-center px-3 py-2 border border-green-300 text-sm font-medium rounded-lg text-green-700 bg-white hover:bg-green-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors duration-200"
           aria-label="Open <%= shopify_domain %> in Shopify Admin (opens in new tab)">
          <svg class="h-4 w-4 mr-2 text-green-600" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M15.337 3.415c-.073-.015-.147.003-.2.052-.053.049-.083.117-.086.19l-.116 1.765-1.262-.32c-.073-.018-.15.003-.208.056-.058.054-.089.13-.085.208l.21 3.88-1.79-.454c-.074-.019-.152.003-.21.058-.059.054-.089.132-.083.21l.303 3.81-1.71-.435c-.074-.019-.152.003-.21.058-.058.054-.088.131-.082.208l.21 2.9-.003.026c-.002.082.027.161.08.22.053.058.127.093.206.096l4.387.137c.077.002.152-.024.21-.074.059-.05.098-.12.11-.196l.847-4.803c.024-.135-.041-.27-.163-.34l-1.03-.593.206-3.167 1.13.287c.077.02.157-.001.217-.057.06-.055.092-.134.086-.214l-.21-3.182 1.064.27c.077.02.157-.002.217-.058.06-.056.092-.135.086-.215l-.116-1.767c-.006-.08-.046-.154-.11-.205-.063-.05-.146-.074-.226-.064l-1.54.156z"/>
          </svg>
          Shopify Admin
          <svg class="h-3.5 w-3.5 ml-1.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      <% end %>

      <a href="<%= shopify8_dashboard_url %>"
         target="_blank"
         rel="noopener noreferrer"
         class="flex-1 inline-flex items-center justify-center px-3 py-2 border border-blue-300 text-sm font-medium rounded-lg text-blue-700 bg-white hover:bg-blue-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors duration-200"
         aria-label="Open Shopify8 sync dashboard (opens in new tab)">
        <svg class="h-4 w-4 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
        Shopify8 Dashboard
        <svg class="h-3.5 w-3.5 ml-1.5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>

    <%# Async-loaded sync status via Turbo Frame %>
    <div class="border-t border-gray-200 pt-4">
      <%= turbo_frame_tag "sync-status-#{catalog.code}",
          src: sync_status_frame_src,
          loading: :lazy do %>
        <%# Skeleton placeholder while loading %>
        <div aria-busy="true" aria-label="Loading sync status">
          <div class="animate-pulse space-y-3">
            <div class="h-4 bg-gray-200 rounded w-1/3"></div>
            <div class="h-3 bg-gray-200 rounded w-full"></div>
            <div class="h-3 bg-gray-200 rounded w-5/6"></div>
            <div class="h-3 bg-gray-200 rounded w-4/6"></div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
